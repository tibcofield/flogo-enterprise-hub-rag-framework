{
  "imports": [
    "github.com/project-flogo/flow",
    "github.com/project-flogo/contrib/activity/noop",
    "github.com/tibco/flogo-ai-agent/src/app/AgenticAI/activity/agentactivity",
    "github.com/project-flogo/websocket/activity/wswritedata",
    "github.com/tibco/flogo-ai-agent/src/app/AgenticAI/activity/callagent",
    "github.com/tibco/flogo-general/src/app/General/activity/log",
    "github.com/project-flogo/contrib/activity/actreturn",
    "github.com/project-flogo/websocket/trigger/wsserver",
    "github.com/tibco/flogo-ai-agent/src/app/AgenticAI/trigger/agent",
    "github.com/project-flogo/contrib/function/coerce",
    "github.com/project-flogo/contrib/function/string",
    "github.com/tibco/flogo-ai-agent/src/app/AgenticAI/connector/llmprovider"
  ],
  "name": "MobileCustomerCareHub",
  "description": "Multi-agent Mobile customer care hub. Demonstrates List of Agents for Handoff using AIAgent Activity with agentHandoffs and InvokeAIAgentTrigger for deterministic routing.",
  "version": "1.0.0",
  "type": "flogo:app",
  "appModel": "1.1.1",
  "tags": [],
  "triggers": [
    {
      "ref": "#wsserver",
      "name": "wsserver",
      "description": "WebSocket server for AI-powered customer support on port 9998.",
      "settings": {
        "port": 9998,
        "enableTLS": false,
        "serverCert": "",
        "serverKey": "",
        "enableClientAuth": false,
        "trustStore": ""
      },
      "id": "WebsocketServer",
      "handlers": [
        {
          "description": "Customer care flow using AIAgent Activity with agentHandoffs for non-deterministic routing to specialist agents.",
          "settings": {
            "method": "GET",
            "path": "/customer-care",
            "mode": "Data",
            "format": "String",
            "jsonSchema": ""
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:customerCare_flow"
            },
            "input": {
              "pathParams": "=$.pathParams",
              "queryParams": "=$.queryParams",
              "headers": "=$.headers",
              "content": "=$.content",
              "wsconnection": "=$.wsconnection"
            }
          },
          "schemas": {
            "output": {
              "queryParams": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"sessionId\":{\"type\":\"string\"}},\"required\":[]}",
                "fe_metadata": "[{\"parameterName\":\"sessionId\",\"type\":\"string\",\"repeating\":\"\",\"required\":\"\"}]"
              },
              "headers": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"Accept\":{\"type\":\"string\",\"visible\":false},\"Accept-Charset\":{\"type\":\"string\",\"visible\":false},\"Accept-Encoding\":{\"type\":\"string\",\"visible\":false},\"Content-Type\":{\"type\":\"string\",\"visible\":false},\"Content-Length\":{\"type\":\"string\",\"visible\":false},\"Connection\":{\"type\":\"string\",\"visible\":false},\"Cookie\":{\"type\":\"string\",\"visible\":false},\"Pragma\":{\"type\":\"string\",\"visible\":false},\"Sec-Websocket-Key\":{\"type\":\"string\",\"visible\":false},\"Sec-Websocket-Version\":{\"type\":\"string\",\"visible\":false},\"Upgrade\":{\"type\":\"string\",\"visible\":false}},\"required\":[]}",
                "fe_metadata": "[{\"parameterName\":\"Accept\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Charset\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Encoding\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Type\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Length\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Connection\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Cookie\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Pragma\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Sec-Websocket-Key\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Sec-Websocket-Version\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Upgrade\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false}]"
              }
            }
          },
          "name": "customerCare_flow"
        },
        {
          "description": "Billing flow using InvokeAIAgentTrigger to call BillingSpecialistAgent directly.",
          "settings": {
            "method": "GET",
            "path": "/billing",
            "mode": "Data",
            "format": "String",
            "jsonSchema": ""
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:directBilling_flow"
            },
            "input": {
              "pathParams": "=$.pathParams",
              "queryParams": "=$.queryParams",
              "headers": "=$.headers",
              "content": "=$.content",
              "wsconnection": "=$.wsconnection"
            }
          },
          "schemas": {
            "output": {
              "headers": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"Accept\":{\"type\":\"string\",\"visible\":false},\"Accept-Charset\":{\"type\":\"string\",\"visible\":false},\"Accept-Encoding\":{\"type\":\"string\",\"visible\":false},\"Content-Type\":{\"type\":\"string\",\"visible\":false},\"Content-Length\":{\"type\":\"string\",\"visible\":false},\"Connection\":{\"type\":\"string\",\"visible\":false},\"Cookie\":{\"type\":\"string\",\"visible\":false},\"Pragma\":{\"type\":\"string\",\"visible\":false},\"Sec-Websocket-Key\":{\"type\":\"string\",\"visible\":false},\"Sec-Websocket-Version\":{\"type\":\"string\",\"visible\":false},\"Upgrade\":{\"type\":\"string\",\"visible\":false}},\"required\":[]}",
                "fe_metadata": "[{\"parameterName\":\"Accept\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Charset\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Encoding\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Type\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Length\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Connection\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Cookie\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Pragma\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Sec-Websocket-Key\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Sec-Websocket-Version\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Upgrade\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false}]"
              }
            }
          },
          "name": "directBilling_flow"
        }
      ]
    },
    {
      "ref": "#agent",
      "name": "flogo-agenticai-agent",
      "description": "Billing specialist agent for charge disputes, payment history and account credits.",
      "settings": {
        "llmProviderConnection": "conn://22222222-2222-2222-2222-222222222222",
        "agentName": "=$property[\"BillingSpecialistAgent.Trigger_Settings.AgentName\"]",
        "agentDescription": "=$property[\"BillingSpecialistAgent.Trigger_Settings.AgentDescription\"]",
        "agentType": "Local",
        "agentPort": 8081,
        "model": "=$property[\"BillingSpecialistAgent.Trigger_Settings.LLM_Model\"]",
        "reasoning": "",
        "temperature": "=$property[\"BillingSpecialistAgent.Trigger_Settings.LLM_temperature\"]",
        "enableGuardrails": true,
        "rateLimit": "=$property[\"BillingSpecialistAgent.Trigger_Settings.Rate_Limit\"]",
        "tokenLimit": "=$property[\"BillingSpecialistAgent.Trigger_Settings.Token_Limit\"]",
        "redactSensitiveData": "=$property[\"BillingSpecialistAgent.Trigger_Settings.Redact_Sensitive_Data\"]",
        "mcpServers": [],
        "conversationStoreType": "Memory",
        "memoryMaxSize": 20,
        "systemPrompt": "You are a Mobile Billing Specialist AI. You are the authoritative source for all billing, payment, and account charge questions.\n\n## Your Expertise\n- Monthly bill breakdown and itemized charges\n- Payment history and current balance\n- International roaming and add-on charges\n- Goodwill credits and billing adjustments\n- Late payment fees and promotional discounts\n- Plan pricing questions\n\n## Your Tools\n- **GetBillDetails**: Retrieves the full itemized bill for a customer's account and billing period. Call this first whenever the customer mentions their bill, charges, or payment amount.\n- **ApplyBillCredit**: Applies a credit or adjustment to a customer's account after verifying legitimacy of the claim.\n\n## Credit Approval Policy\n- Goodwill credits up to $25.00: approve directly\n- Credits $25.01–$100.00: approve with customer acknowledgment of issue resolution\n- Credits over $100.00: inform customer it requires supervisor review within 24 hours\n\n## Response Style\n- Empathetic and reassuring — billing issues are stressful\n- Be precise with dollar amounts and due dates\n- Always confirm the action taken: 'I have applied a $12.00 credit — your new balance is $97.98'\n- Never repeat back full payment card numbers or government ID numbers"
      },
      "id": "BillingSpecialistAgent",
      "handlers": [
        {
          "description": "GetBillDetails tool flow for BillingSpecialistAgent. Returns itemized bill data.",
          "settings": {
            "handlerType": "Tool",
            "agentToolName": "GetBillDetails",
            "agentToolDescription": "Retrieves the complete itemized bill for a Mobile account for a specific billing period. Returns plan charges, additional charges (roaming, add-ons), total amount due, due date, last payment info, and data/voice/SMS usage summary. Always call this first when the customer asks about their bill, a specific charge, or their current balance.",
            "customGuardrailType": "BOTH",
            "customConversationStoreOperation": "STORE"
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:get_bill_details_flow"
            },
            "input": {
              "toolParams": "=$.toolParams"
            },
            "output": {
              "response": "=$.response"
            }
          },
          "schemas": {
            "reply": {
              "response": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}"
              },
              "customConversationStoreOpOutput": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"success\": {\r\n      \"type\": \"boolean\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"success\"\r\n  ]\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"success\": {\r\n      \"type\": \"boolean\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"success\"\r\n  ]\r\n}"
              }
            },
            "output": {
              "toolParams": {
                "type": "json",
                "value": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"accountId\": {\"type\": \"string\"},\n    \"billingPeriod\": {\"type\": \"string\"}\n  },\n  \"required\": [\"accountId\"]\n}",
                "fe_metadata": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"accountId\": {\"type\": \"string\"},\n    \"billingPeriod\": {\"type\": \"string\"}\n  },\n  \"required\": [\"accountId\"]\n}"
              },
              "customGuardrailInput": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"isRequest\": {\r\n      \"type\": \"boolean\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"data\",\"isRequest\"\r\n ]\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"isRequest\": {\r\n      \"type\": \"boolean\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"data\",\"isRequest\"\r\n ]\r\n}"
              },
              "customConversationStoreOpInput": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"conversationId\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"message\": {\r\n      \"type\": \"object\",\r\n      \"properties\": {\r\n        \"role\": {\r\n          \"type\": \"string\",\r\n          \"enum\":[\"user\", \"assistant\", \"system\", \"tool\"]\r\n        },\r\n        \"content\": {\r\n          \"type\": \"string\"\r\n        },\r\n        \"metadata\": {\r\n          \"type\": \"object\"\r\n        }\r\n      },\r\n      \"required\": [\r\n        \"role\",\r\n        \"content\",\r\n        \"metadata\"\r\n      ]\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"conversationId\",\r\n    \"message\"\r\n  ]\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"conversationId\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"message\": {\r\n      \"type\": \"object\",\r\n      \"properties\": {\r\n        \"role\": {\r\n          \"type\": \"string\",\r\n          \"enum\":[\"user\", \"assistant\", \"system\", \"tool\"]\r\n        },\r\n        \"content\": {\r\n          \"type\": \"string\"\r\n        },\r\n        \"metadata\": {\r\n          \"type\": \"object\"\r\n        }\r\n      },\r\n      \"required\": [\r\n        \"role\",\r\n        \"content\",\r\n        \"metadata\"\r\n      ]\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"conversationId\",\r\n    \"message\"\r\n  ]\r\n}"
              }
            }
          },
          "name": "get_bill_details_flow"
        },
        {
          "description": "ApplyBillCredit tool flow for BillingSpecialistAgent. Applies a billing credit to the account.",
          "settings": {
            "handlerType": "Tool",
            "agentToolName": "ApplyBillCredit",
            "agentToolDescription": "Applies a credit or monetary adjustment to a Mobile customer account. Use when the customer has a legitimate billing dispute, was incorrectly charged, or qualifies for a goodwill credit. Always call GetBillDetails first to confirm the disputed charge before applying a credit.",
            "customGuardrailType": "BOTH",
            "customConversationStoreOperation": "STORE"
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:apply_bill_credit_flow"
            },
            "input": {
              "toolParams": "=$.toolParams"
            },
            "output": {
              "response": "=$.response"
            }
          },
          "schemas": {
            "reply": {
              "response": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}"
              },
              "customConversationStoreOpOutput": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"success\": {\r\n      \"type\": \"boolean\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"success\"\r\n  ]\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"success\": {\r\n      \"type\": \"boolean\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"success\"\r\n  ]\r\n}"
              }
            },
            "output": {
              "toolParams": {
                "type": "json",
                "value": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"accountId\": {\"type\": \"string\"},\n    \"creditAmount\": {\"type\": \"number\"},\n    \"creditReason\": {\"type\": \"string\"}\n  },\n  \"required\": [\"accountId\", \"creditAmount\", \"creditReason\"]\n}",
                "fe_metadata": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"accountId\": {\"type\": \"string\"},\n    \"creditAmount\": {\"type\": \"number\"},\n    \"creditReason\": {\"type\": \"string\"}\n  },\n  \"required\": [\"accountId\", \"creditAmount\", \"creditReason\"]\n}"
              },
              "customGuardrailInput": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"isRequest\": {\r\n      \"type\": \"boolean\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"data\",\"isRequest\"\r\n ]\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"isRequest\": {\r\n      \"type\": \"boolean\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"data\",\"isRequest\"\r\n ]\r\n}"
              },
              "customConversationStoreOpInput": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"conversationId\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"message\": {\r\n      \"type\": \"object\",\r\n      \"properties\": {\r\n        \"role\": {\r\n          \"type\": \"string\",\r\n          \"enum\":[\"user\", \"assistant\", \"system\", \"tool\"]\r\n        },\r\n        \"content\": {\r\n          \"type\": \"string\"\r\n        },\r\n        \"metadata\": {\r\n          \"type\": \"object\"\r\n        }\r\n      },\r\n      \"required\": [\r\n        \"role\",\r\n        \"content\",\r\n        \"metadata\"\r\n      ]\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"conversationId\",\r\n    \"message\"\r\n  ]\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"conversationId\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"message\": {\r\n      \"type\": \"object\",\r\n      \"properties\": {\r\n        \"role\": {\r\n          \"type\": \"string\",\r\n          \"enum\":[\"user\", \"assistant\", \"system\", \"tool\"]\r\n        },\r\n        \"content\": {\r\n          \"type\": \"string\"\r\n        },\r\n        \"metadata\": {\r\n          \"type\": \"object\"\r\n        }\r\n      },\r\n      \"required\": [\r\n        \"role\",\r\n        \"content\",\r\n        \"metadata\"\r\n      ]\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"conversationId\",\r\n    \"message\"\r\n  ]\r\n}"
              }
            }
          },
          "name": "apply_bill_credit_flow"
        }
      ]
    },
    {
      "ref": "#agent",
      "name": "flogo-agenticai-agent",
      "description": "Technical support agent for connectivity issues, diagnostics and technician scheduling. Can hand off to UpgradeAdvisorAgent.",
      "settings": {
        "llmProviderConnection": "conn://22222222-2222-2222-2222-222222222222",
        "agentName": "=$property[\"TechnicalSupportAgent.Trigger_Settings.AgentName\"]",
        "agentDescription": "=$property[\"TechnicalSupportAgent.Trigger_Settings.AgentDescription\"]",
        "agentType": "Local",
        "agentPort": 8082,
        "model": "=$property[\"TechnicalSupportAgent.Trigger_Settings.LLM_Model\"]",
        "reasoning": "",
        "temperature": "=$property[\"TechnicalSupportAgent.Trigger_Settings.LLM_temperature\"]",
        "enableGuardrails": false,
        "rateLimit": "=$property[\"TechnicalSupportAgent.Trigger_Settings.Rate_Limit\"]",
        "tokenLimit": "=$property[\"TechnicalSupportAgent.Trigger_Settings.Token_Limit\"]",
        "redactSensitiveData": "=$property[\"TechnicalSupportAgent.Trigger_Settings.Redact_Sensitive_Data\"]",
        "mcpServers": [],
        "conversationStoreType": "Memory",
        "memoryMaxSize": 20,
        "systemPrompt": "You are a Mobile Technical Support Specialist AI. You diagnose network and device issues and coordinate field technician visits.\n\n## Your Expertise\n- Mobile and home internet connectivity troubleshooting\n- 5G/LTE/4G signal strength and coverage issues\n- SIM card and device compatibility problems\n- Router and modem configuration\n- Network outage identification\n- Scheduling field technician home visits\n\n## Your Tools\n- **RunLineDiagnostics**: Runs a real-time network diagnostic on the customer's line. Always run this first when the customer reports connectivity problems. Returns signal strength, download/upload speeds, detected issues, and recommendations.\n- **ScheduleTechnicianVisit**: Books a field technician to visit the customer's address for hands-on repair. Use when remote diagnostics cannot resolve the issue, or hardware replacement is needed.\n\n## Handoff to UpgradeAdvisorAgent\nIf RunLineDiagnostics reveals the customer's device is incompatible with 5G or is more than 3 years old, and a device upgrade would resolve the issue — hand off to UpgradeAdvisorAgent. Frame it positively: 'Your device may be limiting your experience — let me connect you with our Upgrade Advisor to explore modern options.'\n\n## Escalation Path\n1. Run diagnostics first\n2. Try guided remote fixes (SIM refresh, settings change)\n3. Schedule technician visit if remote fix fails\n4. Suggest device upgrade if device is the root cause\n\n## Tone\n- Patient and methodical — customers are frustrated when things don't work\n- Explain what you're doing: 'I'm running a diagnostic on your line now...'\n- Give concrete next steps, not vague advice"
      },
      "id": "TechnicalSupportAgent",
      "handlers": [
        {
          "description": "RunLineDiagnostics tool flow for TechnicalSupportAgent. Runs network diagnostics on the customer line.",
          "settings": {
            "handlerType": "Tool",
            "agentToolName": "RunLineDiagnostics",
            "agentToolDescription": "Runs a real-time network diagnostic on the customer's Mobile line. Returns signal strength, network type (5G/LTE/4G), download and upload speeds, latency, packet loss percentage, a list of detected issues, and recommended next steps. Always call this first when a customer reports connectivity problems, slow data, dropped calls, or no signal.",
            "customGuardrailType": "BOTH",
            "customConversationStoreOperation": "STORE"
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:run_line_diagnostics_flow"
            },
            "input": {
              "toolParams": "=$.toolParams"
            },
            "output": {
              "response": "=$.response"
            }
          },
          "schemas": {
            "reply": {
              "response": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}",
