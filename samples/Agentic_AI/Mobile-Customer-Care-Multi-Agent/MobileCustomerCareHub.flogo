      "id": "flow:customerCare_flow",
      "data": {
        "name": "customerCare_flow",
        "description": "Customer care flow using AIAgent Activity with agentHandoffs for non-deterministic routing to specialist agents.",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "CustomerSupportDispatcher",
            "type": "label",
            "label": "StartActivity to CustomerSupportDispatcher"
          },
          {
            "id": 2,
            "from": "CustomerSupportDispatcher",
            "to": "WebsocketWriteData",
            "type": "label",
            "label": "CustomerSupportDispatcher to WebsocketWriteData"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "NoOp Activity",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "CustomerSupportDispatcher",
            "name": "CustomerSupportDispatcher",
            "description": "AIAgent Activity dispatcher. Routes customer messages to specialist agents using agentHandoffs.",
            "activity": {
              "ref": "#agentactivity",
              "settings": {
                "llmProviderConnection": "conn://22222222-2222-2222-2222-222222222222",
                "model": "=$property[\"CustomerSupportDispatcher.Activity_Settings.LLM_Model\"]",
                "reasoning": "",
                "temperature": 1,
                "enableGuardrails": true,
                "rateLimit": "=$property[\"CustomerSupportDispatcher.Activity_Settings.Rate_Limit\"]",
                "tokenLimit": "=$property[\"CustomerSupportDispatcher.Activity_Settings.Token_Limit\"]",
                "redactSensitiveData": "=$property[\"CustomerSupportDispatcher.Activity_Settings.Redact_Sensitive_Data\"]",
                "responseType": "Text",
                "agentHandoffs": "=$property[\"CustomerSupportDispatcher.Activity_Settings.Agents_Handoff\"]",
                "mcpServers": [],
                "conversationStoreType": "Memory",
                "memoryMaxSize": 20,
                "systemPrompt": "You are Alex, a friendly and highly efficient AI customer care dispatcher for Mobile — a leading Mobile provider.\n\n## Your Role\nYou are the first point of contact for Mobile customers. Your job is to greet the customer, understand their issue, and route them to the right specialist — or handle simple inquiries yourself.\n\n## Routing Rules\n- **Billing questions** (charges, payment, statements, credits, refunds, incorrect charges) → hand off to BillingSpecialistAgent\n- **Technical issues** (no signal, slow data, dropped calls, router problems, device connectivity, internet outages) → hand off to TechnicalSupportAgent\n- **Plan or device upgrades** (new plan options, device upgrade, better 5G coverage, faster speeds) → hand off to UpgradeAdvisorAgent\n- **Simple questions** (store hours, general account info, contact numbers) → handle directly\n\n## Handoff Style\n- Announce handoffs naturally: 'Let me connect you with our Billing Specialist right away...'\n- Never say 'I am transferring you to another AI system' — frame it as connecting to a team member\n- Briefly summarize the customer's issue when handing off so the specialist has immediate context\n- If the request spans multiple domains, prioritize the most urgent issue first\n\n## Tone\n- Warm, patient, and professional\n- Acknowledge frustration empathetically before routing: 'I understand how frustrating that can be — let me get the right person on this for you.'\n- Keep your own responses brief; let the specialists handle the depth"
              },
              "input": {
                "userPrompt": "=coerce.toString($flow.content)",
                "conversationId": "=string.concat(\"care-session-\", coerce.toString($flow.queryParams.sessionId))"
              }
            }
          },
          {
            "id": "WebsocketWriteData",
            "name": "WebsocketWriteData",
            "description": "Writes the agent response back to the customer over WebSocket.",
            "activity": {
              "ref": "#wswritedata",
              "settings": {
                "format": "String",
                "jsonSchema": ""
              },
              "input": {
                "message": "=$activity[CustomerSupportDispatcher].response",
                "wsconnection": "=$flow.wsconnection"
              }
            }
          }
        ],
        "fe_metadata": "eyJTdGFydEFjdGl2aXR5Ijp7IngiOjUwLCJ5Ijo1MH0sIkN1c3RvbWVyU3VwcG9ydERpc3BhdGNoZXIiOnsieCI6MjQyLCJ5Ijo0NX0sIldlYnNvY2tldFdyaXRlRGF0YSI6eyJ4Ijo0NjMsInkiOjQ3fX0=",
        "metadata": {
          "input": [
            {
              "name": "pathParams",
              "type": "params"
            },
            {
              "name": "queryParams",
              "type": "params"
            },
            {
              "name": "headers",
              "type": "object",
              "schema": {
                "type": "json",
                "value": "{\"Accept\":{\"type\":\"string\",\"visible\":false},\"Accept-Charset\":{\"type\":\"string\",\"visible\":false},\"Accept-Encoding\":{\"type\":\"string\",\"visible\":false},\"Content-Type\":{\"type\":\"string\",\"visible\":false},\"Content-Length\":{\"type\":\"string\",\"visible\":false},\"Connection\":{\"type\":\"string\",\"visible\":false},\"Cookie\":{\"type\":\"string\",\"visible\":false},\"Pragma\":{\"type\":\"string\",\"visible\":false},\"Sec-Websocket-Key\":{\"type\":\"string\",\"visible\":false},\"Sec-Websocket-Version\":{\"type\":\"string\",\"visible\":false},\"Upgrade\":{\"type\":\"string\",\"visible\":false}}"
              }
            },
            {
              "name": "content",
              "type": "any"
            },
            {
              "name": "wsconnection",
              "type": "any"
            }
          ],
          "output": [],
          "fe_metadata": {
            "input": "{\"type\":\"object\",\"title\":\"WebsocketServer\",\"properties\":{\"pathParams\":{\"type\":\"params\"},\"queryParams\":{\"type\":\"params\"},\"headers\":{\"type\":\"object\",\"properties\":{\"Accept\":{\"type\":\"string\",\"visible\":false},\"Accept-Charset\":{\"type\":\"string\",\"visible\":false},\"Accept-Encoding\":{\"type\":\"string\",\"visible\":false},\"Content-Type\":{\"type\":\"string\",\"visible\":false},\"Content-Length\":{\"type\":\"string\",\"visible\":false},\"Connection\":{\"type\":\"string\",\"visible\":false},\"Cookie\":{\"type\":\"string\",\"visible\":false},\"Pragma\":{\"type\":\"string\",\"visible\":false},\"Sec-Websocket-Key\":{\"type\":\"string\",\"visible\":false},\"Sec-Websocket-Version\":{\"type\":\"string\",\"visible\":false},\"Upgrade\":{\"type\":\"string\",\"visible\":false}},\"required\":[]},\"content\":{\"type\":\"any\",\"required\":false},\"wsconnection\":{\"type\":\"any\",\"required\":false}}}"
          }
        }
      }
    },
    {
      "id": "flow:directBilling_flow",
      "data": {
        "name": "directBilling_flow",
        "description": "Billing flow using InvokeAIAgentTrigger to call BillingSpecialistAgent directly.",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "InvokeBillingAgentDirect",
            "type": "label",
            "label": "StartActivity to InvokeBillingAgentDirect"
          },
          {
            "id": 2,
            "from": "InvokeBillingAgentDirect",
            "to": "WebsocketWriteData",
            "type": "label",
            "label": "InvokeBillingAgentDirect to WebsocketWriteData"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "NoOp Activity",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "InvokeBillingAgentDirect",
            "name": "InvokeBillingAgentDirect",
            "description": "InvokeAIAgentTrigger activity that calls BillingSpecialistAgent directly by name.",
            "activity": {
              "ref": "#callagent",
              "settings": {
                "agentType": "Local"
              },
              "input": {
                "agentName": "BillingSpecialistAgent",
                "agentBaseUrl": "",
                "prompt": "=coerce.toString($flow.content)",
                "structuredOutput": false,
                "conversationId": "=string.concat(\"billing-direct-\", coerce.toString($flow.queryParams.sessionId))"
              }
            }
          },
          {
            "id": "WebsocketWriteData",
            "name": "WebsocketWriteData",
            "description": "Writes the BillingSpecialistAgent response back to the customer over WebSocket.",
