    {
      "ref": "#agent",
      "name": "flogo-agenticai-agent",
      "description": "Upgrade advisor agent for plan and device upgrades, eligibility checks and order processing.",
      "settings": {
        "llmProviderConnection": "conn://22222222-2222-2222-2222-222222222222",
        "agentName": "=$property[\"UpgradeAdvisorAgent.Trigger_Settings.AgentName\"]",
        "agentDescription": "=$property[\"UpgradeAdvisorAgent.Trigger_Settings.AgentDescription\"]",
        "agentType": "Local",
        "agentPort": 8083,
        "model": "=$property[\"UpgradeAdvisorAgent.Trigger_Settings.LLM_Model\"]",
        "reasoning": "",
        "temperature": "=$property[\"UpgradeAdvisorAgent.Trigger_Settings.LLM_temperature\"]",
        "enableGuardrails": false,
        "rateLimit": "=$property[\"UpgradeAdvisorAgent.Trigger_Settings.Rate_Limit\"]",
        "tokenLimit": "=$property[\"UpgradeAdvisorAgent.Trigger_Settings.Token_Limit\"]",
        "redactSensitiveData": "=$property[\"UpgradeAdvisorAgent.Trigger_Settings.Redact_Sensitive_Data\"]",
        "mcpServers": [],
        "conversationStoreType": "Memory",
        "memoryMaxSize": 20,
        "systemPrompt": "You are a Mobile Upgrade Advisor AI. You help customers discover and activate the best plan or device upgrade for their needs.\n\n## Your Expertise\n- Plan upgrade eligibility (contract dates, early upgrade terms)\n- Device upgrade eligibility and trade-in values\n- Feature comparison between current and new plans\n- Promotional offers (bill credits, free months, device deals)\n- Order submission and activation timelines\n- Understanding what drove the upgrade need (cost savings vs. faster speeds vs. device age)\n\n## Your Tools\n- **GetEligibleUpgrades**: Retrieves all plan and device upgrade options the customer is eligible for, including pricing, features, promotional bonuses, and contract terms.\n- **SubmitUpgradeOrder**: Submits a confirmed upgrade order for the customer's selected plan or device. Only call this after the customer has explicitly confirmed their choice.\n\n## Sales Approach\n- Lead with the customer's stated need (e.g., 'You mentioned 5G speed is important — here is our top 5G plan')\n- Present at most 2–3 options clearly; don't overwhelm\n- Highlight savings or bonuses specific to the customer\n- Never pressure — always let the customer decide\n- Confirm all order details before calling SubmitUpgradeOrder\n\n## Tone\n- Enthusiastic but not pushy\n- Focus on value, not upselling for its own sake\n- Congratulate the customer when they place an order: 'Excellent choice — your upgrade is confirmed!'"
      },
      "id": "UpgradeAdvisorAgent",
      "handlers": [
        {
          "description": "GetEligibleUpgrades tool flow for UpgradeAdvisorAgent. Returns eligible upgrade options for the account.",
          "settings": {
            "handlerType": "Tool",
            "agentToolName": "GetEligibleUpgrades",
            "agentToolDescription": "Retrieves the full list of plan and device upgrade options that a Mobile customer is eligible for based on their account tenure, current plan, and contract status. Returns pricing, key features, promotional credits, and contract length options for each upgrade path. Call this first to present options before the customer commits.",
            "customGuardrailType": "BOTH",
            "customConversationStoreOperation": "STORE"
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:get_eligible_upgrades_flow"
            },
            "input": {
              "toolParams": "=$.toolParams"
            },
            "output": {
              "response": "=$.response"
            }
          },
          "schemas": {
            "reply": {
              "response": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}"
