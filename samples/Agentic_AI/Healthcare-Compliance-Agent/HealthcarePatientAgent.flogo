{
  "imports": [
    "github.com/project-flogo/flow",
    "github.com/project-flogo/contrib/activity/noop",
    "github.com/tibco/flogo-ai-agent/src/app/AgenticAI/activity/callagent",
    "github.com/project-flogo/websocket/activity/wswritedata",
    "github.com/tibco/flogo-general/src/app/General/activity/log",
    "github.com/project-flogo/contrib/activity/actreturn",
    "github.com/tibco/flogo-files/src/app/File/activity/read",
    "github.com/tibco/flogo-general/src/app/General/activity/parsejson",
    "github.com/tibco/flogo-files/src/app/File/activity/write",
    "github.com/project-flogo/websocket/trigger/wsserver",
    "github.com/tibco/flogo-ai-agent/src/app/AgenticAI/trigger/agent",
    "github.com/project-flogo/contrib/function/string",
    "github.com/project-flogo/contrib/function/coerce",
    "git.tibco.com/git/product/ipaas/wi-contrib.git/function/boolean",
    "github.com/project-flogo/contrib/function/array",
    "github.com/tibco/flogo-ai-agent/src/app/AgenticAI/connector/llmprovider"
  ],
  "name": "HealthcarePatientAgent",
  "description": "HIPAA-aware AI patient support assistant using OpenAI GPT-5.4. Features a custom PHI guardrail (SSN/DOB/MRN redaction) and a file-based custom conversation store for compliance audit trails.",
  "version": "1.0.0",
  "type": "flogo:app",
  "appModel": "1.1.1",
  "tags": [],
  "triggers": [
    {
      "ref": "#wsserver",
      "name": "wsserver",
      "description": "WebSocket server — patients connect here to chat with the healthcare support agent",
      "settings": {
        "port": 9998,
        "enableTLS": false,
        "serverCert": "",
        "serverKey": "",
        "enableClientAuth": false,
        "trustStore": ""
      },
      "id": "WebsocketServer",
      "handlers": [
        {
          "description": "Receives patient messages via WebSocket and dispatches them to the HealthcarePatientAgent",
          "settings": {
            "method": "GET",
            "path": "/patient-support",
            "mode": "Data",
            "format": "String",
            "jsonSchema": ""
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:callHealthcareAgent_flow"
            },
            "input": {
              "pathParams": "=$.pathParams",
              "queryParams": "=$.queryParams",
              "headers": "=$.headers",
              "content": "=$.content",
              "wsconnection": "=$.wsconnection"
            }
          },
          "schemas": {
            "output": {
              "queryParams": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"sessionId\":{\"type\":\"string\"}},\"required\":[]}",
                "fe_metadata": "[{\"parameterName\":\"sessionId\",\"type\":\"string\",\"repeating\":\"\",\"required\":\"\"}]"
              },
              "headers": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"Accept\":{\"type\":\"string\",\"visible\":false},\"Accept-Charset\":{\"type\":\"string\",\"visible\":false},\"Accept-Encoding\":{\"type\":\"string\",\"visible\":false},\"Content-Type\":{\"type\":\"string\",\"visible\":false},\"Content-Length\":{\"type\":\"string\",\"visible\":false},\"Connection\":{\"type\":\"string\",\"visible\":false},\"Cookie\":{\"type\":\"string\",\"visible\":false},\"Pragma\":{\"type\":\"string\",\"visible\":false},\"Sec-Websocket-Key\":{\"type\":\"string\",\"visible\":false},\"Sec-Websocket-Version\":{\"type\":\"string\",\"visible\":false},\"Upgrade\":{\"type\":\"string\",\"visible\":false}},\"required\":[]}",
                "fe_metadata": "[{\"parameterName\":\"Accept\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Charset\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Encoding\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Type\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Length\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Connection\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Cookie\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Pragma\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Sec-Websocket-Key\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Sec-Websocket-Version\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Upgrade\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false}]"
              }
            }
          },
          "name": "callHealthcareAgent_flow"
        }
      ]
    },
    {
      "ref": "#agent",
      "name": "flogo-agenticai-agent",
      "description": "Healthcare Patient Support Agent — HIPAA-aware, with custom PHI guardrail, file-based conversation store, and 3 patient-service tools.",
      "settings": {
        "llmProviderConnection": "conn://22222222-2222-2222-2222-222222222222",
        "agentName": "=$property[\"Trigger_Settings.AgentName\"]",
        "agentDescription": "=$property[\"Trigger_Settings.AgentDescription\"]",
        "agentType": "Local",
        "agentPort": 8081,
        "model": "=$property[\"Trigger_Settings.LLM_Model\"]",
        "reasoning": "",
        "temperature": "=$property[\"Trigger_Settings.LLM_temperature\"]",
        "enableGuardrails": true,
        "rateLimit": "=$property[\"Trigger_Settings.Rate_Limit\"]",
        "tokenLimit": "=$property[\"Trigger_Settings.Token_Limit\"]",
        "redactSensitiveData": "=$property[\"Trigger_Settings.Redact_Sensitive_Data\"]",
        "mcpServers": [],
        "conversationStoreType": "Custom Store",
        "memoryMaxSize": 30,
        "systemPrompt": "You are a compassionate and knowledgeable patient support assistant for HealthBridge Medical Group. Your role is to help patients navigate their healthcare journey with empathy, clarity, and respect.\n\n## Core Principles\n- **Patient privacy first**: Never encourage patients to share SSN, full DOB, or Medical Record Numbers in chat. If they do, remind them this channel is not the appropriate place for sensitive identifiers.\n- **Non-diagnostic**: You provide general health information and coordinate services — you are not a doctor and cannot diagnose conditions or prescribe medications.\n- **Empathy**: Many patients are anxious or unwell. Respond with warmth and patience.\n- **Clarity**: Use plain language. Avoid medical jargon unless the patient uses it first.\n\n## What You Can Help With\n- Checking appointment availability and suggesting times (use CheckAppointmentSlots tool)\n- Finding nearby clinics and urgent care centers (use FindNearestClinic tool)\n- Providing general medication guidance — side effects, storage, interactions (use GetMedicationGuide tool)\n- Explaining next steps for common procedures\n- Answering general questions about the healthcare provider's services\n\n## What You Should NOT Do\n- Diagnose medical conditions\n- Recommend specific medications or dosing changes\n- Access or discuss specific patient medical records\n- Promise specific wait times or outcomes\n\n## Privacy Reminders\nIf a patient begins sharing sensitive identifiers (SSN, full DOB, MRN), gently redirect them:\n\"For your security, please don't share sensitive identifiers here. For identity verification, our staff will contact you securely through verified channels.\"\n\n## Response Style\n- Begin with acknowledgment of the patient's concern\n- Provide clear, actionable next steps\n- End with an offer to help further or connect them with human staff if needed"
      },
      "id": "HealthcarePatientAgent",
      "handlers": [
        {
          "description": "Custom PHI Guardrail: Receives pre-processed customGuardrailInput (SSN already redacted at handler level) and applies additional DOB and MRN redaction before returning sanitized data to the LLM pipeline.",
          "settings": {
            "handlerType": "Custom Guardrail",
            "agentToolName": "",
            "agentToolDescription": "",
            "customGuardrailType": "BOTH",
            "customConversationStoreOperation": "STORE"
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:phi_guardrail_flow"
            },
            "input": {
              "customGuardrailInput": {
                "@conditional": [
                  {
                    "string.contains($.customGuardrailInput.data, \"\\\\d{3}-\\\\d{2}-\\\\d{4}\")": {
                      "data": "=string.replaceRegEx(\"\\\\d{3}-\\\\d{2}-\\\\d{4}\", $.customGuardrailInput.data, \"XXX-XX-XXXX\")",
                      "isRequest": "=$.customGuardrailInput.isRequest"
                    }
                  },
                  {
                    "@otherwise": {
                      "data": "=$.customGuardrailInput.data",
                      "isRequest": "=$.customGuardrailInput.isRequest"
                    }
                  }
                ]
              }
            },
            "output": {
              "response": "=$.response"
            }
          },
          "schemas": {
            "reply": {
              "response": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}"
              },
              "customConversationStoreOpOutput": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"success\": {\r\n      \"type\": \"boolean\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"success\"\r\n  ]\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"success\": {\r\n      \"type\": \"boolean\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"success\"\r\n  ]\r\n}"
              }
            },
            "output": {
              "customGuardrailInput": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"isRequest\": {\r\n      \"type\": \"boolean\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"data\",\"isRequest\"\r\n ]\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"isRequest\": {\r\n      \"type\": \"boolean\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"data\",\"isRequest\"\r\n ]\r\n}"
              },
              "customConversationStoreOpInput": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"conversationId\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"message\": {\r\n      \"type\": \"object\",\r\n      \"properties\": {\r\n        \"role\": {\r\n          \"type\": \"string\",\r\n          \"enum\":[\"user\", \"assistant\", \"system\", \"tool\"]\r\n        },\r\n        \"content\": {\r\n          \"type\": \"string\"\r\n        },\r\n        \"metadata\": {\r\n          \"type\": \"object\"\r\n        }\r\n      },\r\n      \"required\": [\r\n        \"role\",\r\n        \"content\",\r\n        \"metadata\"\r\n      ]\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"conversationId\",\r\n    \"message\"\r\n  ]\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"conversationId\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"message\": {\r\n      \"type\": \"object\",\r\n      \"properties\": {\r\n        \"role\": {\r\n          \"type\": \"string\",\r\n          \"enum\":[\"user\", \"assistant\", \"system\", \"tool\"]\r\n        },\r\n        \"content\": {\r\n          \"type\": \"string\"\r\n        },\r\n        \"metadata\": {\r\n          \"type\": \"object\"\r\n        }\r\n      },\r\n      \"required\": [\r\n        \"role\",\r\n        \"content\",\r\n        \"metadata\"\r\n      ]\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"conversationId\",\r\n    \"message\"\r\n  ]\r\n}"
              }
            }
          },
          "name": "phi_guardrail_flow"
        },
        {
          "description": "Custom Conversation Store STORE: Reads the existing per-session JSON file, appends the new message enriched with HIPAA-context metadata, then writes the updated session back. Per-session isolation: each patient conversationId maps to its own {conversationId}.json file under HealthcareAgent.ConversationDir. Pattern follows the AI_CustSore.json reference: Read -> ParseJSON -> array.append -> Write.",
          "settings": {
            "handlerType": "Custom Conversation Store",
            "agentToolName": "",
            "agentToolDescription": "",
            "customGuardrailType": "BOTH",
            "customConversationStoreOperation": "STORE"
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:store_conversation_flow"
            },
            "input": {
              "customConversationStoreOpInput": {
                "mapping": {
                  "conversationId": "=$.customConversationStoreOpInput.conversationId",
                  "message": {
                    "role": "=$.customConversationStoreOpInput.message.role",
                    "content": "=$.customConversationStoreOpInput.message.content",
                    "metadata": {
                      "sessionId": "=$.customConversationStoreOpInput.conversationId",
                      "channel": "websocket",
                      "phiHandled": true,
                      "dataClassification": "PHI_PROTECTED",
                      "patientPortalVersion": "2.0"
                    }
                  }
                }
              }
            },
            "output": {
              "customConversationStoreOpOutput": "=$.customConversationStoreOpOutput"
            }
          },
          "schemas": {
            "reply": {
              "response": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}"
              },
              "customConversationStoreOpOutput": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"success\": {\r\n      \"type\": \"boolean\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"success\"\r\n  ]\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"success\": {\r\n      \"type\": \"boolean\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"success\"\r\n  ]\r\n}"
              }
            },
            "output": {
              "customGuardrailInput": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"isRequest\": {\r\n      \"type\": \"boolean\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"data\",\"isRequest\"\r\n ]\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"isRequest\": {\r\n      \"type\": \"boolean\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"data\",\"isRequest\"\r\n ]\r\n}"
              },
              "customConversationStoreOpInput": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"conversationId\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"message\": {\r\n      \"type\": \"object\",\r\n      \"properties\": {\r\n        \"role\": {\r\n          \"type\": \"string\",\r\n          \"enum\":[\"user\", \"assistant\", \"system\", \"tool\"]\r\n        },\r\n        \"content\": {\r\n          \"type\": \"string\"\r\n        },\r\n        \"metadata\": {\r\n          \"type\": \"object\"\r\n        }\r\n      },\r\n      \"required\": [\r\n        \"role\",\r\n        \"content\",\r\n        \"metadata\"\r\n      ]\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"conversationId\",\r\n    \"message\"\r\n  ]\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"conversationId\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"message\": {\r\n      \"type\": \"object\",\r\n      \"properties\": {\r\n        \"role\": {\r\n          \"type\": \"string\",\r\n          \"enum\":[\"user\", \"assistant\", \"system\", \"tool\"]\r\n        },\r\n        \"content\": {\r\n          \"type\": \"string\"\r\n        },\r\n        \"metadata\": {\r\n          \"type\": \"object\"\r\n        }\r\n      },\r\n      \"required\": [\r\n        \"role\",\r\n        \"content\",\r\n        \"metadata\"\r\n      ]\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"conversationId\",\r\n    \"message\"\r\n  ]\r\n}"
              }
            }
          },
          "name": "store_conversation_flow"
        },
        {
          "description": "Custom Conversation Store FETCH: Reads the per-session JSON file for this conversationId and returns the full message history to the agent. Unlike the single-file reference (which filtered by hardcoded ID), per-session files eliminate the filter entirely — each file IS one patient conversation.",
          "settings": {
            "handlerType": "Custom Conversation Store",
            "agentToolName": "",
            "agentToolDescription": "",
            "customGuardrailType": "BOTH",
            "customConversationStoreOperation": "FETCH"
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:fetch_conversation_flow"
            },
            "input": {
              "customConversationStoreOpInput": "=$.customConversationStoreOpInput"
            },
            "output": {
              "customConversationStoreOpOutput": "=$.customConversationStoreOpOutput"
            }
          },
          "schemas": {
            "reply": {
              "response": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}"
              },
              "customConversationStoreOpOutput": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"success\": {\r\n      \"type\": \"boolean\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"messages\": {\r\n      \"type\": \"array\",\r\n      \"items\": {\r\n        \"type\": \"object\",\r\n        \"properties\": {\r\n          \"role\": {\r\n            \"type\": \"string\"\r\n          },\r\n          \"content\": {\r\n            \"type\": \"string\"\r\n          },\r\n          \"metadata\": {\r\n            \"type\": \"object\",\r\n            \"properties\": {}\r\n          }\r\n        },\r\n        \"required\": [\"role\",\"content\"]\r\n      }\r\n    }\r\n  },\r\n  \"required\": [\"success\",\"messages\"]\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"success\": {\r\n      \"type\": \"boolean\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"messages\": {\r\n      \"type\": \"array\",\r\n      \"items\": {\r\n        \"type\": \"object\",\r\n        \"properties\": {\r\n          \"role\": {\r\n            \"type\": \"string\"\r\n          },\r\n          \"content\": {\r\n            \"type\": \"string\"\r\n          },\r\n          \"metadata\": {\r\n            \"type\": \"object\",\r\n            \"properties\": {}\r\n          }\r\n        },\r\n        \"required\": [\"role\",\"content\"]\r\n      }\r\n    }\r\n  },\r\n  \"required\": [\"success\",\"messages\"]\r\n}"
              }
            },
            "output": {
              "customGuardrailInput": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"isRequest\": {\r\n      \"type\": \"boolean\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"data\",\"isRequest\"\r\n ]\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"isRequest\": {\r\n      \"type\": \"boolean\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"data\",\"isRequest\"\r\n ]\r\n}"
              },
              "customConversationStoreOpInput": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"conversationId\": {\r\n      \"type\": \"string\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"conversationId\"\r\n  ]\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"conversationId\": {\r\n      \"type\": \"string\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"conversationId\"\r\n  ]\r\n}"
              }
            }
          },
          "name": "fetch_conversation_flow"
        },
        {
          "description": "Tool handler: Returns available appointment slots. Replace Return with InvokeRestService to your EHR/scheduling system (Epic, Cerner, etc.) in production.",
          "settings": {
            "handlerType": "Tool",
            "agentToolName": "CheckAppointmentSlots",
            "agentToolDescription": "Checks available appointment slots for a given medical department or specific doctor. Returns a list of available date/time slots. Use when a patient asks about booking or scheduling an appointment.",
            "customGuardrailType": "BOTH",
            "customConversationStoreOperation": "STORE"
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:check_appointments_flow"
            },
            "input": {
              "toolParams": "=$.toolParams"
            },
            "output": {
              "response": "=$.response"
            }
          },
          "schemas": {
            "reply": {
              "response": {
