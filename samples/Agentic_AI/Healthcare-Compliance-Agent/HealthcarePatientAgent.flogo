  "resources": [
    {
      "id": "flow:callHealthcareAgent_flow",
      "data": {
        "name": "callHealthcareAgent_flow",
        "description": "Receives patient messages via WebSocket and dispatches them to the HealthcarePatientAgent",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "CallHealthcareAgent",
            "type": "label",
            "label": "StartActivity to CallHealthcareAgent"
          },
          {
            "id": 2,
            "from": "CallHealthcareAgent",
            "to": "WebsocketWriteData",
            "type": "label",
            "label": "CallHealthcareAgent to WebsocketWriteData"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "NoOp Activity",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "CallHealthcareAgent",
            "name": "CallHealthcareAgent",
            "description": "Invokes the Healthcare Patient Agent. The sessionId query parameter is used as the conversationId for multi-turn memory and the custom conversation store file name.",
            "activity": {
              "ref": "#callagent",
              "settings": {
                "agentType": "Local"
              },
              "input": {
                "agentName": "HealthcarePatientAgent",
                "agentBaseUrl": "",
                "prompt": "=coerce.toString($flow.content)",
                "structuredOutput": false,
                "conversationId": "=coerce.toString($flow.queryParams.sessionId)"
              }
            }
          },
          {
            "id": "WebsocketWriteData",
            "name": "WebsocketWriteData",
            "description": "Streams the agent's response back to the patient over WebSocket",
            "activity": {
              "ref": "#wswritedata",
              "settings": {
                "format": "String",
                "jsonSchema": ""
              },
              "input": {
                "message": "=$activity[CallHealthcareAgent].response",
                "wsconnection": "=$flow.wsconnection"
              }
            }
          }
        ],
        "fe_metadata": "eyJTdGFydEFjdGl2aXR5Ijp7IngiOjUwLCJ5Ijo1MH0sIkNhbGxIZWFsdGhjYXJlQWdlbnQiOnsieCI6MjExLCJ5Ijo1M30sIldlYnNvY2tldFdyaXRlRGF0YSI6eyJ4Ijo0MTYsInkiOjQ5fX0=",
        "metadata": {
          "input": [
            {
              "name": "pathParams",
              "type": "params"
            },
            {
              "name": "queryParams",
              "type": "params"
            },
            {
              "name": "headers",
              "type": "object",
              "schema": {
                "type": "json",
                "value": "{\"Accept\":{\"type\":\"string\",\"visible\":false},\"Accept-Charset\":{\"type\":\"string\",\"visible\":false},\"Accept-Encoding\":{\"type\":\"string\",\"visible\":false},\"Content-Type\":{\"type\":\"string\",\"visible\":false},\"Content-Length\":{\"type\":\"string\",\"visible\":false},\"Connection\":{\"type\":\"string\",\"visible\":false},\"Cookie\":{\"type\":\"string\",\"visible\":false},\"Pragma\":{\"type\":\"string\",\"visible\":false},\"Sec-Websocket-Key\":{\"type\":\"string\",\"visible\":false},\"Sec-Websocket-Version\":{\"type\":\"string\",\"visible\":false},\"Upgrade\":{\"type\":\"string\",\"visible\":false}}"
              }
            },
            {
              "name": "content",
              "type": "any"
            },
            {
              "name": "wsconnection",
              "type": "any"
            }
          ],
          "output": [],
          "fe_metadata": {
            "input": "{\"type\":\"object\",\"title\":\"WebsocketServer\",\"properties\":{\"pathParams\":{\"type\":\"params\"},\"queryParams\":{\"type\":\"params\"},\"headers\":{\"type\":\"object\",\"properties\":{\"Accept\":{\"type\":\"string\",\"visible\":false},\"Accept-Charset\":{\"type\":\"string\",\"visible\":false},\"Accept-Encoding\":{\"type\":\"string\",\"visible\":false},\"Content-Type\":{\"type\":\"string\",\"visible\":false},\"Content-Length\":{\"type\":\"string\",\"visible\":false},\"Connection\":{\"type\":\"string\",\"visible\":false},\"Cookie\":{\"type\":\"string\",\"visible\":false},\"Pragma\":{\"type\":\"string\",\"visible\":false},\"Sec-Websocket-Key\":{\"type\":\"string\",\"visible\":false},\"Sec-Websocket-Version\":{\"type\":\"string\",\"visible\":false},\"Upgrade\":{\"type\":\"string\",\"visible\":false}},\"required\":[]},\"content\":{\"type\":\"any\",\"required\":false},\"wsconnection\":{\"type\":\"any\",\"required\":false}}}"
          }
        }
      }
    },
    {
      "id": "flow:phi_guardrail_flow",
      "data": {
        "name": "phi_guardrail_flow",
        "description": "Custom PHI Guardrail: Receives pre-processed customGuardrailInput (SSN already redacted at handler level) and applies additional DOB and MRN redaction before returning sanitized data to the LLM pipeline.",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "LogPHIGuardrail",
            "type": "label",
            "label": "StartActivity to LogPHIGuardrail"
          },
          {
            "id": 2,
            "from": "LogPHIGuardrail",
            "to": "ReturnSanitizedData",
            "type": "label",
            "label": "LogPHIGuardrail to ReturnSanitizedData"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "NoOp Activity",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "LogPHIGuardrail",
            "name": "LogPHIGuardrail",
            "description": "Logs the guardrail invocation direction (input=patient→LLM, output=LLM→patient)",
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": false,
                "message": "=string.concat(\"[PHIGuardrail] direction=\", string.concat(coerce.toString($flow.customGuardrailInput.isRequest), \" — PHI redaction applied\"))",
                "logLevel": ""
              }
            }
          },
          {
            "id": "ReturnSanitizedData",
            "name": "ReturnSanitizedData",
            "description": "Returns sanitized data: SSN was already redacted by the handler-level @conditional; applies DOB (\\d{4}-\\d{2}-\\d{2} → ****-**-**) and MRN (MRN-\\d{6,10} → MRN-XXXXXXXX) on the handler-processed value.",
            "activity": {
              "ref": "#actreturn",
              "settings": {
                "mappings": {
                  "response": {
                    "mapping": {
                      "data": "=string.replaceRegEx(\"MRN-\\\\d{6,10}\", string.replaceRegEx(\"\\\\d{4}-\\\\d{2}-\\\\d{2}\", $flow.customGuardrailInput.data, \"****-**-**\"), \"MRN-XXXXXXXX\")",
                      "error": ""
                    }
                  }
                }
              }
            }
          }
        ],
        "fe_metadata": "eyJTdGFydEFjdGl2aXR5Ijp7IngiOjEwMCwieSI6MTAwfSwiTG9nUEhJR3VhcmRyYWlsIjp7IngiOjI3NSwieSI6OTJ9LCJSZXR1cm5TYW5pdGl6ZWREYXRhIjp7IngiOjQ4MCwieSI6OTF9fQ==",
        "metadata": {
          "input": [
            {
              "name": "customGuardrailInput",
              "type": "object",
              "schema": {
                "type": "json",
                "value": "{\"data\":{\"type\":\"string\"},\"isRequest\":{\"type\":\"boolean\"}}"
              }
            }
          ],
          "output": [
            {
              "name": "response",
              "type": "object",
              "schema": {
                "type": "json",
                "value": "{\"data\":{\"type\":\"string\"},\"error\":{\"type\":\"string\"}}"
              }
            }
          ],
          "fe_metadata": {
            "input": "{\"type\":\"object\",\"title\":\"HealthcarePatientAgent\",\"properties\":{\"customGuardrailInput\":{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"data\":{\"type\":\"string\"},\"isRequest\":{\"type\":\"boolean\"}},\"required\":[\"data\",\"isRequest\"]}}}",
            "output": "{\"type\":\"object\",\"title\":\"Inputs\",\"properties\":{\"response\":{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"data\":{\"type\":\"string\"},\"error\":{\"type\":\"string\"}}}},\"required\":[]}"
          }
        }
      }
    },
    {
      "id": "flow:store_conversation_flow",
      "data": {
        "name": "store_conversation_flow",
        "description": "Custom Conversation Store STORE: Reads the existing per-session JSON file, appends the new message enriched with HIPAA-context metadata, then writes the updated session back. Per-session isolation: each patient conversationId maps to its own {conversationId}.json file under HealthcareAgent.ConversationDir. Pattern follows the AI_CustSore.json reference: Read -> ParseJSON -> array.append -> Write.",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "LogStore",
            "type": "label",
            "label": "StartActivity to LogStore"
          },
          {
            "id": 2,
            "from": "LogStore",
            "to": "ReadSessionFile",
            "type": "label",
            "label": "LogStore to ReadSessionFile"
          },
          {
            "id": 3,
            "from": "ReadSessionFile",
            "to": "ParseSessionJSON",
            "type": "label",
            "label": "ReadSessionFile to ParseSessionJSON"
          },
          {
            "id": 4,
            "from": "ParseSessionJSON",
            "to": "WriteUpdatedSession",
            "type": "label",
            "label": "ParseSessionJSON to WriteUpdatedSession"
          },
          {
            "id": 5,
            "from": "WriteUpdatedSession",
            "to": "ReturnStoreSuccess",
            "type": "label",
            "label": "WriteUpdatedSession to ReturnStoreSuccess"
          },
          {
            "id": 6,
            "from": "ReadSessionFile",
            "to": "WriteNewSession",
            "type": "error",
            "label": "ReadSessionFile to WriteNewSession (new session bootstrap)"
          },
          {
            "id": 7,
            "from": "WriteNewSession",
            "to": "ReturnStoreSuccess",
            "type": "label",
            "label": "WriteNewSession to ReturnStoreSuccess"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "NoOp Activity",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "LogStore",
            "name": "LogStore",
            "description": "Logs the store operation with role and conversationId for HIPAA audit observability",
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": false,
                "message": "=string.concat(\"[PHIConvStore STORE] conversationId=\",$flow.customConversationStoreOpInput.conversationId,\" role=\",$flow.customConversationStoreOpInput.message.role)",
                "logLevel": ""
              }
            }
          },
          {
            "id": "ReadSessionFile",
            "name": "ReadSessionFile",
            "description": "Reads the existing per-session conversation JSON file. Format: {conversationId, messages[]}. Each patient conversationId maps to its own isolated file. Self-bootstrapping: if the file does not exist (new session), the error link routes to WriteNewSession to create it automatically.",
            "activity": {
              "ref": "#read",
              "input": {
                "readAs": "Text",
                "compress": "None",
                "input": {
                  "mapping": {
                    "fileName": "=string.concat($property[\"HealthcareAgent.ConversationDir\"],\"/\",$flow.customConversationStoreOpInput.conversationId,\".json\")"
                  }
                }
              },
              "schemas": {
                "input": {
                  "input": {
                    "type": "json",
                    "value": "{\"properties\":{\"fileName\":{\"type\":\"string\"}},\"required\":[\"fileName\"],\"type\":\"object\"}",
                    "fe_metadata": "{\"properties\":{\"fileName\":{\"type\":\"string\"}},\"required\":[\"fileName\"],\"type\":\"object\"}"
                  }
                },
                "output": {
                  "output": {
                    "type": "json",
                    "value": "{\"properties\":{\"fileMetadata\":{\"properties\":{\"fullPath\":{\"type\":\"string\"},\"name\":{\"type\":\"string\"},\"size\":{\"type\":\"number\"},\"mode\":{\"type\":\"string\"},\"modTime\":{\"type\":\"string\",\"format\":\"date-time\"},\"isDir\":{\"type\":\"boolean\"}},\"type\":\"object\"},\"fileContent\":{\"properties\":{\"textContent\":{\"type\":\"string\"}},\"type\":\"object\"}},\"type\":\"object\"}",
                    "fe_metadata": "{\"properties\":{\"fileMetadata\":{\"properties\":{\"fullPath\":{\"type\":\"string\"},\"name\":{\"type\":\"string\"},\"size\":{\"type\":\"number\"},\"mode\":{\"type\":\"string\"},\"modTime\":{\"type\":\"string\",\"format\":\"date-time\"},\"isDir\":{\"type\":\"boolean\"}},\"type\":\"object\"},\"fileContent\":{\"properties\":{\"textContent\":{\"type\":\"string\"}},\"type\":\"object\"}},\"type\":\"object\"}"
                  }
                }
              },
              "feSchemaMap": {}
            }
          },
          {
            "id": "ParseSessionJSON",
            "name": "ParseSessionJSON",
            "description": "Parses the session JSON file content into a structured object. Schema matches per-session format: {conversationId, messages[{role,content,metadata}]} with HIPAA metadata fields (sessionId, channel, phiHandled, dataClassification, patientPortalVersion).",
            "activity": {
              "ref": "#parsejson",
              "input": {
                "validate": false,
                "jsonString": "=$activity[ReadSessionFile].output.fileContent.textContent"
              },
              "schemas": {
                "output": {
                  "jsonObject": {
                    "type": "json",
                    "value": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"conversationId\": {\"type\": \"string\"},\n    \"messages\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"role\": {\"type\": \"string\", \"enum\": [\"user\", \"assistant\", \"system\", \"tool\"]},\n          \"content\": {\"type\": \"string\"},\n          \"metadata\": {\n            \"type\": \"object\",\n            \"properties\": {\n              \"sessionId\": {\"type\": \"string\"},\n              \"channel\": {\"type\": \"string\"},\n              \"phiHandled\": {\"type\": \"boolean\"},\n              \"dataClassification\": {\"type\": \"string\"},\n              \"patientPortalVersion\": {\"type\": \"string\"}\n            }\n          }\n        },\n        \"required\": [\"role\", \"content\"],\n        \"additionalProperties\": false\n      }\n    }\n  },\n  \"required\": [\"conversationId\", \"messages\"],\n  \"additionalProperties\": false\n}",
                    "fe_metadata": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"conversationId\": {\"type\": \"string\"},\n    \"messages\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"role\": {\"type\": \"string\", \"enum\": [\"user\", \"assistant\", \"system\", \"tool\"]},\n          \"content\": {\"type\": \"string\"},\n          \"metadata\": {\n            \"type\": \"object\",\n            \"properties\": {\n              \"sessionId\": {\"type\": \"string\"},\n              \"channel\": {\"type\": \"string\"},\n              \"phiHandled\": {\"type\": \"boolean\"},\n              \"dataClassification\": {\"type\": \"string\"},\n              \"patientPortalVersion\": {\"type\": \"string\"}\n            }\n          }\n        },\n        \"required\": [\"role\", \"content\"],\n        \"additionalProperties\": false\n      }\n    }\n  },\n  \"required\": [\"conversationId\", \"messages\"],\n  \"additionalProperties\": false\n}"
                  }
                }
              },
              "feSchemaMap": {}
            }
          },
          {
            "id": "WriteUpdatedSession",
            "name": "WriteUpdatedSession",
            "description": "Writes the updated session JSON back to the per-session file using array.append() — identical pattern to the AI_CustSore.json reference app. createNonExistingDir auto-creates the conversations/ directory on first use.",
            "activity": {
              "ref": "#write",
              "input": {
                "writeAs": "Text",
                "createNonExistingDir": true,
                "compress": "None",
                "input": {
                  "mapping": {
                    "overwrite": "=boolean.true()",
                    "fileName": "=string.concat($property[\"HealthcareAgent.ConversationDir\"],\"/\",$flow.customConversationStoreOpInput.conversationId,\".json\")",
                    "textContent": "=string.concat(\"{\\\"conversationId\\\":\\\"\",$flow.customConversationStoreOpInput.conversationId,\"\\\",\\\"messages\\\":\",coerce.toString(array.append(($activity[ParseSessionJSON].jsonObject.messages),$flow.customConversationStoreOpInput.message)),\"}\")"
                  }
                }
              },
              "schemas": {
                "input": {
                  "input": {
                    "type": "json",
                    "value": "{\"properties\":{\"fileName\":{\"type\":\"string\"},\"overwrite\":{\"type\":\"boolean\"},\"textContent\":{\"type\":\"string\"}},\"required\":[\"fileName\",\"overwrite\",\"textContent\"],\"type\":\"object\"}",
                    "fe_metadata": "{\"properties\":{\"fileName\":{\"type\":\"string\"},\"overwrite\":{\"type\":\"boolean\"},\"textContent\":{\"type\":\"string\"}},\"required\":[\"fileName\",\"overwrite\",\"textContent\"],\"type\":\"object\"}"
                  }
                },
                "output": {
                  "output": {
                    "type": "json",
                    "value": "{\"properties\":{\"fileMetadata\":{\"properties\":{\"fullPath\":{\"type\":\"string\"},\"name\":{\"type\":\"string\"},\"size\":{\"type\":\"number\"},\"mode\":{\"type\":\"string\"},\"modTime\":{\"type\":\"string\",\"format\":\"date-time\"},\"isDir\":{\"type\":\"boolean\"}},\"type\":\"object\"}},\"type\":\"object\"}",
                    "fe_metadata": "{\"properties\":{\"fileMetadata\":{\"properties\":{\"fullPath\":{\"type\":\"string\"},\"name\":{\"type\":\"string\"},\"size\":{\"type\":\"number\"},\"mode\":{\"type\":\"string\"},\"modTime\":{\"type\":\"string\",\"format\":\"date-time\"},\"isDir\":{\"type\":\"boolean\"}},\"type\":\"object\"}},\"type\":\"object\"}"
                  }
                }
              },
              "feSchemaMap": {}
            }
          },
          {
            "id": "ReturnStoreSuccess",
            "name": "ReturnStoreSuccess",
            "description": "Returns success to the agent after appending the message to the per-session conversation file.",
            "activity": {
              "ref": "#actreturn",
              "settings": {
                "mappings": {
                  "customConversationStoreOpOutput": {
                    "mapping": {
                      "success": "=boolean.true()"
                    }
                  }
                }
              }
            }
          },
          {
            "id": "WriteNewSession",
            "name": "WriteNewSession",
            "description": "New session bootstrap: file did not exist so create a new session JSON with the current message as the first entry. Auto-creates the conversations/ directory. No seed file required.",
            "activity": {
              "ref": "#write",
              "input": {
                "writeAs": "Text",
                "createNonExistingDir": true,
                "compress": "None",
                "input": {
                  "mapping": {
                    "overwrite": "=boolean.true()",
                    "fileName": "=string.concat($property[\"HealthcareAgent.ConversationDir\"],\"/\",$flow.customConversationStoreOpInput.conversationId,\".json\")",
                    "textContent": "=string.concat(\"{\\\"conversationId\\\":\\\"\",$flow.customConversationStoreOpInput.conversationId,\"\\\",\\\"messages\\\":[\",coerce.toString($flow.customConversationStoreOpInput.message),\"]}\")"
                  }
                }
              },
              "schemas": {
                "input": {
                  "input": {
                    "type": "json",
                    "value": "{\"properties\":{\"fileName\":{\"type\":\"string\"},\"overwrite\":{\"type\":\"boolean\"},\"textContent\":{\"type\":\"string\"}},\"required\":[\"fileName\",\"overwrite\",\"textContent\"],\"type\":\"object\"}",
                    "fe_metadata": "{\"properties\":{\"fileName\":{\"type\":\"string\"},\"overwrite\":{\"type\":\"boolean\"},\"textContent\":{\"type\":\"string\"}},\"required\":[\"fileName\",\"overwrite\",\"textContent\"],\"type\":\"object\"}"
                  }
                },
                "output": {
                  "output": {
                    "type": "json",
                    "value": "{\"properties\":{\"fileMetadata\":{\"properties\":{\"fullPath\":{\"type\":\"string\"},\"name\":{\"type\":\"string\"},\"size\":{\"type\":\"number\"},\"mode\":{\"type\":\"string\"},\"modTime\":{\"type\":\"string\",\"format\":\"date-time\"},\"isDir\":{\"type\":\"boolean\"}},\"type\":\"object\"}},\"type\":\"object\"}",
                    "fe_metadata": "{\"properties\":{\"fileMetadata\":{\"properties\":{\"fullPath\":{\"type\":\"string\"},\"name\":{\"type\":\"string\"},\"size\":{\"type\":\"number\"},\"mode\":{\"type\":\"string\"},\"modTime\":{\"type\":\"string\",\"format\":\"date-time\"},\"isDir\":{\"type\":\"boolean\"}},\"type\":\"object\"}},\"type\":\"object\"}"
                  }
                }
              },
              "feSchemaMap": {}
            }
          }
        ],
        "fe_metadata": "",
        "metadata": {
          "input": [
            {
              "name": "customConversationStoreOpInput",
              "type": "object",
              "schema": {
                "type": "json",
                "value": "{\"conversationId\":{\"type\":\"string\"},\"message\":{\"type\":\"object\",\"properties\":{\"role\":{\"type\":\"string\"},\"content\":{\"type\":\"string\"},\"metadata\":{\"type\":\"object\",\"properties\":{}}}}}"
              }
            }
          ],
          "output": [
            {
              "name": "customConversationStoreOpOutput",
              "type": "object",
              "schema": {
                "type": "json",
                "value": "{\"success\":{\"type\":\"boolean\"},\"error\":{\"type\":\"string\"}}"
              }
            }
          ],
          "fe_metadata": {
            "input": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"customConversationStoreOpInput\":{\"type\":\"object\",\"properties\":{\"conversationId\":{\"type\":\"string\"},\"message\":{\"type\":\"object\",\"properties\":{\"role\":{\"type\":\"string\"},\"content\":{\"type\":\"string\"},\"metadata\":{\"type\":\"object\",\"properties\":{}}}}}}}}",
            "output": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"customConversationStoreOpOutput\":{\"type\":\"object\",\"properties\":{\"success\":{\"type\":\"boolean\"},\"error\":{\"type\":\"string\"}}}}}"
          }
        }
      }
    },
    {
      "id": "flow:fetch_conversation_flow",
      "data": {
        "name": "fetch_conversation_flow",
        "description": "Custom Conversation Store FETCH: Reads the per-session JSON file for this conversationId and returns the full message history to the agent. Unlike the single-file reference (which filtered by hardcoded ID), per-session files eliminate the filter entirely — each file IS one patient conversation.",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "LogFetch",
            "type": "label",
            "label": "StartActivity to LogFetch"
          },
          {
            "id": 2,
            "from": "LogFetch",
            "to": "ReadSessionFile",
            "type": "label",
            "label": "LogFetch to ReadSessionFile"
          },
          {
            "id": 3,
            "from": "ReadSessionFile",
            "to": "ParseSessionJSON",
            "type": "label",
            "label": "ReadSessionFile to ParseSessionJSON"
          },
          {
            "id": 4,
            "from": "ParseSessionJSON",
            "to": "ReturnMessages",
            "type": "label",
            "label": "ParseSessionJSON to ReturnMessages"
          },
          {
            "id": 5,
            "from": "ReadSessionFile",
            "to": "ReturnEmptyMessages",
            "type": "error",
            "label": "ReadSessionFile to ReturnEmptyMessages (new session bootstrap)"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "NoOp Activity",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "LogFetch",
            "name": "LogFetch",
            "description": "Logs the fetch request for observability and HIPAA audit trail",
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": false,
                "message": "=string.concat(\"[PHIConvStore FETCH] Retrieving history for conversationId=\",$flow.customConversationStoreOpInput.conversationId)",
                "logLevel": ""
              }
            }
          },
          {
            "id": "ReadSessionFile",
            "name": "ReadSessionFile",
            "description": "Reads the per-session conversation JSON file named by conversationId. Each patient session has its own isolated {conversationId}.json file. Self-bootstrapping: if the file does not exist (new session), the error link routes to ReturnEmptyMessages automatically.",
            "activity": {
              "ref": "#read",
              "input": {
                "readAs": "Text",
                "compress": "None",
                "input": {
                  "mapping": {
                    "fileName": "=string.concat($property[\"HealthcareAgent.ConversationDir\"],\"/\",$flow.customConversationStoreOpInput.conversationId,\".json\")"
                  }
                }
              },
              "schemas": {
                "input": {
                  "input": {
                    "type": "json",
                    "value": "{\"properties\":{\"fileName\":{\"type\":\"string\"}},\"required\":[\"fileName\"],\"type\":\"object\"}",
                    "fe_metadata": "{\"properties\":{\"fileName\":{\"type\":\"string\"}},\"required\":[\"fileName\"],\"type\":\"object\"}"
                  }
                },
                "output": {
                  "output": {
                    "type": "json",
                    "value": "{\"properties\":{\"fileMetadata\":{\"properties\":{\"fullPath\":{\"type\":\"string\"},\"name\":{\"type\":\"string\"},\"size\":{\"type\":\"number\"},\"mode\":{\"type\":\"string\"},\"modTime\":{\"type\":\"string\",\"format\":\"date-time\"},\"isDir\":{\"type\":\"boolean\"}},\"type\":\"object\"},\"fileContent\":{\"properties\":{\"textContent\":{\"type\":\"string\"}},\"type\":\"object\"}},\"type\":\"object\"}",
                    "fe_metadata": "{\"properties\":{\"fileMetadata\":{\"properties\":{\"fullPath\":{\"type\":\"string\"},\"name\":{\"type\":\"string\"},\"size\":{\"type\":\"number\"},\"mode\":{\"type\":\"string\"},\"modTime\":{\"type\":\"string\",\"format\":\"date-time\"},\"isDir\":{\"type\":\"boolean\"}},\"type\":\"object\"},\"fileContent\":{\"properties\":{\"textContent\":{\"type\":\"string\"}},\"type\":\"object\"}},\"type\":\"object\"}"
                  }
                }
              },
              "feSchemaMap": {}
            }
          },
          {
            "id": "ParseSessionJSON",
            "name": "ParseSessionJSON",
            "description": "Parses the session JSON file content. Schema matches the per-session format {conversationId, messages[]} with HIPAA metadata fields. minItems:0 allows empty (new) sessions.",
            "activity": {
              "ref": "#parsejson",
              "input": {
                "validate": false,
                "jsonString": "=$activity[ReadSessionFile].output.fileContent.textContent"
              },
              "schemas": {
                "output": {
                  "jsonObject": {
                    "type": "json",
                    "value": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"conversationId\": {\"type\": \"string\"},\n    \"messages\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"role\": {\"type\": \"string\", \"enum\": [\"user\", \"assistant\", \"system\", \"tool\"]},\n          \"content\": {\"type\": \"string\"},\n          \"metadata\": {\n            \"type\": \"object\",\n            \"properties\": {\n              \"sessionId\": {\"type\": \"string\"},\n              \"channel\": {\"type\": \"string\"},\n              \"phiHandled\": {\"type\": \"boolean\"},\n              \"dataClassification\": {\"type\": \"string\"},\n              \"patientPortalVersion\": {\"type\": \"string\"}\n            }\n          }\n        },\n        \"required\": [\"role\", \"content\"],\n        \"additionalProperties\": false\n      },\n      \"minItems\": 0\n    }\n  },\n  \"required\": [\"conversationId\", \"messages\"],\n  \"additionalProperties\": false\n}",
                    "fe_metadata": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"conversationId\": {\"type\": \"string\"},\n    \"messages\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"role\": {\"type\": \"string\", \"enum\": [\"user\", \"assistant\", \"system\", \"tool\"]},\n          \"content\": {\"type\": \"string\"},\n          \"metadata\": {\n            \"type\": \"object\",\n            \"properties\": {\n              \"sessionId\": {\"type\": \"string\"},\n              \"channel\": {\"type\": \"string\"},\n              \"phiHandled\": {\"type\": \"boolean\"},\n              \"dataClassification\": {\"type\": \"string\"},\n              \"patientPortalVersion\": {\"type\": \"string\"}\n            }\n          }\n        },\n        \"required\": [\"role\", \"content\"],\n        \"additionalProperties\": false\n      },\n      \"minItems\": 0\n    }\n  },\n  \"required\": [\"conversationId\", \"messages\"],\n  \"additionalProperties\": false\n}"
                  }
                }
              },
              "feSchemaMap": {}
            }
          },
          {
            "id": "ReturnMessages",
            "name": "ReturnMessages",
            "description": "Returns the full conversation message history to the agent. No conversationId filter needed — each per-session file contains exactly this patient's conversation. The @foreach maps all stored messages to the output array.",
            "activity": {
              "ref": "#actreturn",
              "settings": {
                "mappings": {
                  "customConversationStoreOpOutput": {
                    "mapping": {
                      "success": "=boolean.true()",
                      "messages": {
                        "@foreach($activity[ParseSessionJSON].jsonObject.messages,messages)": {
                          "=": "$loop"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          {
            "id": "ReturnEmptyMessages",
            "name": "ReturnEmptyMessages",
            "description": "New session bootstrap: file did not exist yet so return an empty message history. The agent treats this as a fresh conversation with no prior context.",
            "activity": {
              "ref": "#actreturn",
              "settings": {
                "mappings": {
                  "customConversationStoreOpOutput": {
                    "mapping": {
                      "success": "=boolean.true()",
                      "messages": []
                    }
                  }
                }
              }
            }
          }
        ],
        "fe_metadata": "eyJTdGFydEFjdGl2aXR5Ijp7IngiOjUwLCJ5Ijo1MH0sIkxvZ0ZldGNoIjp7IngiOjI0MiwieSI6Mzh9LCJSZWFkU2Vzc2lvbkZpbGUiOnsieCI6NDQ1LCJ5Ijo0M30sIlBhcnNlU2Vzc2lvbkpTT04iOnsieCI6NjQyLCJ5Ijo0N30sIlJldHVybk1lc3NhZ2VzIjp7IngiOjgxNywieSI6NDZ9LCJSZXR1cm5FbXB0eU1lc3NhZ2VzIjp7IngiOjYzNSwieSI6MTY2fX0=",
        "metadata": {
          "input": [
            {
              "name": "customConversationStoreOpInput",
              "type": "object",
              "schema": {
                "type": "json",
                "value": "{\"conversationId\":{\"type\":\"string\"}}"
              }
            }
          ],
          "output": [
            {
              "name": "customConversationStoreOpOutput",
              "type": "object",
              "schema": {
                "type": "json",
                "value": "{\"success\":{\"type\":\"boolean\"},\"error\":{\"type\":\"string\"},\"messages\":{\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"role\":{\"type\":\"string\"},\"content\":{\"type\":\"string\"},\"metadata\":{\"type\":\"object\",\"properties\":{}}},\"required\":[\"role\",\"content\"]}}}"
              }
            }
          ],
          "fe_metadata": {
            "input": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"customConversationStoreOpInput\":{\"type\":\"object\",\"properties\":{\"conversationId\":{\"type\":\"string\"}}}}}",
            "output": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"customConversationStoreOpOutput\":{\"type\":\"object\",\"properties\":{\"success\":{\"type\":\"boolean\"},\"error\":{\"type\":\"string\"},\"messages\":{\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"role\":{\"type\":\"string\"},\"content\":{\"type\":\"string\"},\"metadata\":{\"type\":\"object\",\"properties\":{}}},\"required\":[\"role\",\"content\"]}}}}}}"
          }
        }
      }
    },
    {
      "id": "flow:check_appointments_flow",
      "data": {
        "name": "check_appointments_flow",
        "description": "Tool handler: Returns available appointment slots. Replace Return with InvokeRestService to your EHR/scheduling system (Epic, Cerner, etc.) in production.",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "LogAppointmentCheck",
            "type": "label",
            "label": "StartActivity to LogAppointmentCheck"
          },
          {
            "id": 2,
            "from": "LogAppointmentCheck",
            "to": "ReturnAppointments",
            "type": "label",
            "label": "LogAppointmentCheck to ReturnAppointments"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
