                    "mapping": {
                      "data": "{\"products\":[{\"product_id\":\"P001\",\"product_name\":\"Industrial Sensor Type-A\",\"product_category\":\"Electronics\",\"unit_price\":149.99,\"current_stock\":450,\"reorder_point\":100,\"preferred_supplier_id\":\"S001\"},{\"product_id\":\"P002\",\"product_name\":\"Industrial Sensor Type-B\",\"product_category\":\"Electronics\",\"unit_price\":299.99,\"current_stock\":12,\"reorder_point\":50,\"preferred_supplier_id\":\"S002\"},{\"product_id\":\"P003\",\"product_name\":\"Safety Valve MK-7\",\"product_category\":\"Mechanical\",\"unit_price\":89.99,\"current_stock\":0,\"reorder_point\":200,\"preferred_supplier_id\":\"S001\"},{\"product_id\":\"P004\",\"product_name\":\"Control Board X200\",\"product_category\":\"Electronics\",\"unit_price\":499.99,\"current_stock\":78,\"reorder_point\":25,\"preferred_supplier_id\":\"S003\"},{\"product_id\":\"P005\",\"product_name\":\"Hydraulic Pump HY-500\",\"product_category\":\"Mechanical\",\"unit_price\":1250.00,\"current_stock\":5,\"reorder_point\":10,\"preferred_supplier_id\":\"S002\"},{\"product_id\":\"P006\",\"product_name\":\"Pneumatic Cylinder PC-100\",\"product_category\":\"Mechanical\",\"unit_price\":220.00,\"current_stock\":340,\"reorder_point\":75,\"preferred_supplier_id\":\"S003\"}]}",
                      "error": ""
                    }
                  }
                }
              }
            }
          }
        ],
