        "anthropicProvider": "=$property[\"AgenticAI.openai.Anthropic_Provider\"]",
        "apiKey": "=$property[\"AgenticAI.openai.API_Key\"]",
        "llmProviderUrl": "=$property[\"AgenticAI.openai.LLM_Base_URL\"]"
      }
    },
    "b2c3d4e5-f6a7-8901-bcde-f12345678901": {
      "id": "b2c3d4e5-f6a7-8901-bcde-f12345678901",
      "name": "inventory_mcp_server",
      "ref": "#mcpserverconfig",
      "isGlobal": false,
      "settings": {
