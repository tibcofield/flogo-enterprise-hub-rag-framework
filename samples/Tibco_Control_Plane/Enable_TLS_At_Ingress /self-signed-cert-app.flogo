  "tags": [],
  "triggers": [
    {
      "ref": "#rest",
      "name": "tibco-wi-rest",
      "description": "Simple REST Trigger",
      "settings": {
        "port": 9998,
        "APISpecUpdate": false,
        "swagger": "",
        "swaggerVersion": "v2",
        "authenticationType": "None",
        "username": "",
        "password": "",
        "apiVersion": "1.0.0",
        "secureConnection": true,
        "serverKey": {
          "filename": "tls-multi.key",
          "content": "SECRET:"
        },
        "caCertificate": {
          "filename": "tls-multi.crt",
          "content": "data:application/x-x509-ca-cert;base64,"
        }
      },
      "id": "ReceiveHTTPMessage",
      "handlers": [
        {
          "description": "Add description",
          "settings": {
            "Method": "GET",
            "reqType": "application/json",
            "Path": "/path",
            "OutputValidation": false
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:flow1"
            },
            "input": {
              "headers": "=$.headers"
            },
            "output": {
              "code": 200,
              "data": "=$.data"
            }
          },
          "reply": {
            "code": 200,
            "configureResponseCodes": false,
            "message": {}
          },
          "schemas": {
            "reply": {
              "data": {
                "type": "json",
                "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"response_from_shared_data\":{\"type\":\"object\",\"properties\":{}}}}",
                "fe_metadata": "{\n    \"response_from_shared_data\":{}\n}"
              },
              "responseBody": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}",
                "fe_metadata": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}"
              }
            },
            "output": {
              "headers": {
