                                        "fe_metadata": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"definitions\":{},\"properties\":{\"SADDResponse\":{\"$id\":\"/properties/result\",\"type\":\"integer\",\"title\":\"The Result Schema \",\"default\":0,\"examples\":[5]}}}"
