id\": \"#/properties/result/items/items\", \n                                            \"type\": \"string\"\n                                        }\n                                    }\n                                }\n                            }\n                        }\n                    }\n                },\n                \"/JSON/JSON.OBJLEN\": {\n                    \"summary\":\"Report the number of keys in the JSON object at path in key\",\n                    \"schema\":{\n                        \"parameters\":{\n                            \"type\":\"object\",\n                            \"properties\":{\n                                \"key\":{\n                                    \"required\":true,\n                                    \"type\":\"string\"\n                                },\n                                \"path\":{\n                                    \"required\":false,\n                                    \"type\":\"string\"\n                                }\n                            },\n                            \"required\": [\"key\"]\n                        },\n                        \"output\": {\n                            \"type\": \"object\",\n                            \"properties\": {\n                                \"result\": {\n                                    \"$id\": \"#/properties/result\", \n                                    \"type\": \"array\",\n                                    \"items\": {\n                                        \"type\": \"integer\"\n                                    }\n                                }\n                            }\n                        }\n                    }\n                }\n            }\n        }"
