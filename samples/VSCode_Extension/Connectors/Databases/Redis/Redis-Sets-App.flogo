ype\": \"integer\",\n                                    \"title\": \"The Result Schema \",\n                                    \"default\": 0,\n                                    \"examples\": [\n                                        5\n                                    ]\n                                }\n                            }\n                        }\n                    }\n        \n                },\n                \"/SortedSets/ZSCORE\": {\n                    \"summary\": \"Returns the score of member in the sorted set at key\",\n                    \"schema\":{\n                        \"parameters\": {\n                            \"type\": \"object\",\n                            \"properties\": {\n                                \"key\":{\n                                    \"required\": true,\n                                    \"type\": \"string\"\n                                },\n                                \"member\":{\n                                    \"required\": true,\n                                    \"type\": \"string\"\n                                }\n                            },\n                            \"required\": [\"key\", \"member\"]\n                        },\n                        \"output\": {\n                            \"type\": \"object\",\n                            \"properties\": {\n                                \"result\": {\n                                    \"$id\": \"/properties/result\",\n                                    \"type\": \"string\",\n                                    \"title\": \"The Result Schema \"\n                                }\n                            }\n                        }\n                    }\n        \n                },\n                \"/SortedSets/ZUNIONSTORE\": {\n                    \"summary\": \"Computes the union of sorted sets given by the specified keys, and stores the result in destination\",\n                    \"schema\":