:\"string\",\"format\":\"date-time\"},\"EmailBouncedReason\":{\"type\":\"string\",\"maxLength\":255},\"EmailBouncedDate\":{\"type\":\"string\",\"format\":\"date-time\"},\"Jigsaw\":{\"type\":\"string\",\"maxLength\":20},\"JigsawContactId\":{\"type\":\"string\",\"maxLength\":20},\"CleanStatus\":{\"type\":\"string\",\"maxLength\":40},\"IndividualId\":{\"type\":\"string\",\"maxLength\":18},\"Level__c\":{\"type\":\"string\",\"maxLength\":255},\"Languages__c\":{\"type\":\"string\",\"maxLength\":100},\"ContactID__c\":{\"type\":\"string\",\"maxLength\":255},\"ContactPhone__c\":{\"type\":\"number\"}}},\"event\":{\"type\":\"object\",\"properties\":{\"replayId\":{\"type\":\"integer\"}}}}},\"channel\":{\"type\":\"string\"}}}"
