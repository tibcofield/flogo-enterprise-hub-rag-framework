    "resources": [
        {
            "id": "flow:SFUpsertWithMySQLDB",
            "data": {
                "name": "SFUpsertWithMySQLDB",
                "description": "In this flow records are getting fetched from mysql database using query and using Salesforce Upsert records from database are getting created in the salesforce if not exist already and updated if already exist.",
                "links": [
                    {
                        "id": 1,
                        "from": "MySQLQuery",
                        "to": "MySQLLogMessage",
                        "type": "label",
                        "label": "MySQLQuery to MySQLLogMessage"
                    },
                    {
                        "id": 2,
                        "from": "MySQLLogMessage",
                        "to": "SalesforceUpsert",
                        "type": "label",
                        "label": "MySQLLogMessage to SalesforceUpsert"
                    },
                    {
                        "id": 3,
                        "from": "SalesforceUpsert",
                        "to": "SFUpsertLogMessage",
                        "type": "label",
                        "label": "SalesforceUpsert to SFUpsertLogMessage"
                    },
                    {
                        "id": 4,
                        "from": "SFUpsertLogMessage",
                        "to": "SalesforceQuery",
                        "type": "label",
                        "label": "SFUpsertLogMessage to SalesforceQuery"
                    },
                    {
                        "id": 5,
                        "from": "SalesforceQuery",
                        "to": "SFQueryLogMessage",
                        "type": "label",
                        "label": "SalesforceQuery to SFQueryLogMessage"
                    },
                    {
                        "id": 6,
                        "from": "SFQueryLogMessage",
                        "to": "Return",
                        "type": "label",
                        "label": "SFQueryLogMessage to Return"
                    }
                ],
                "tasks": [
                    {
                        "id": "MySQLQuery",
                        "name": "MySQLQuery",
                        "description": "This activity executes query on a MySQL database",
                        "settings": {
                            "retryOnError": {
                                "count": 0,
                                "interval": 0
                            }
                        },
                        "activity": {
                            "ref": "#query",
                            "input": {
                                "Connection": "conn://e5e78670-0106-11ec-870d-818b0e110ad3",
                                "QueryName": "",
                                "Query": "select * from customers where customerName like 'To%';",
                                "manualmode": false,
                                "Fields": [
                                    {
                                        "FieldName": "customerNumber",
                                        "Type": "INTEGER",
                                        "Selected": true,
                                        "Parameter": false,
                                        "isEditable": false
                                    },
                                    {
                                        "FieldName": "customerName",
                                        "Type": "VARCHAR",
                                        "Selected": true,
                                        "Parameter": false,
                                        "isEditable": false
                                    },
                                    {
                                        "FieldName": "contactLastName",
                                        "Type": "VARCHAR",
                                        "Selected": true,
                                        "Parameter": false,
                                        "isEditable": false
                                    },
                                    {
                                        "FieldName": "contactFirstName",
                                        "Type": "VARCHAR",
                                        "Selected": true,
                                        "Parameter": false,
                                        "isEditable": false
                                    },
                                    {
                                        "FieldName": "phone",
                                        "Type": "VARCHAR",
                                        "Selected": true,
                                        "Parameter": false,
                                        "isEditable": false
                                    },
                                    {
                                        "FieldName": "addressLine1",
                                        "Type": "VARCHAR",
                                        "Selected": true,
                                        "Parameter": false,
                                        "isEditable": false
                                    },
                                    {
                                        "FieldName": "addressLine2",
                                        "Type": "VARCHAR",
                                        "Selected": true,
                                        "Parameter": false,
                                        "isEditable": false
                                    },
                                    {
                                        "FieldName": "city",
                                        "Type": "VARCHAR",
                                        "Selected": true,
                                        "Parameter": false,
                                        "isEditable": false
                                    },
                                    {
                                        "FieldName": "state",
                                        "Type": "VARCHAR",
                                        "Selected": true,
                                        "Parameter": false,
                                        "isEditable": false
                                    },
                                    {
                                        "FieldName": "postalCode",
                                        "Type": "VARCHAR",
                                        "Selected": true,
                                        "Parameter": false,
                                        "isEditable": false
                                    },
                                    {
                                        "FieldName": "country",
                                        "Type": "VARCHAR",
                                        "Selected": true,
                                        "Parameter": false,
                                        "isEditable": false
                                    },
                                    {
                                        "FieldName": "salesRepEmployeeNumber",
                                        "Type": "INTEGER",
                                        "Selected": true,
                                        "Parameter": false,
                                        "isEditable": false
                                    },
                                    {
                                        "FieldName": "creditLimit",
                                        "Type": "DECIMAL",
                                        "Selected": true,
                                        "Parameter": false,
                                        "isEditable": false
                                    }
                                ],
                                "State": "c0571960-7faa-46f7-979d-086bf114393cselect * from customers where customerName like 'To%';"
                            },
                            "schemas": {
                                "input": {
                                    "input": {
                                        "type": "json",
                                        "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"definitions\":{},\"properties\":{\"parameters\":{\"type\":\"object\",\"properties\":{}}}}",
                                        "fe_metadata": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"definitions\":{},\"properties\":{\"parameters\":{\"type\":\"object\",\"properties\":{}}}}"
                                    }
                                },
                                "output": {
                                    "Output": {
                                        "type": "json",
                                        "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"definitions\":{},\"properties\":{\"records\":{\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"customerNumber\":{\"type\":\"integer\"},\"customerName\":{\"type\":\"string\"},\"contactLastName\":{\"type\":\"string\"},\"contactFirstName\":{\"type\":\"string\"},\"phone\":{\"type\":\"string\"},\"addressLine1\":{\"type\":\"string\"},\"addressLine2\":{\"type\":\"string\"},\"city\":{\"type\":\"string\"},\"state\":{\"type\":\"string\"},\"postalCode\":{\"type\":\"string\"},\"country\":{\"type\":\"string\"},\"salesRepEmployeeNumber\":{\"type\":\"integer\"},\"creditLimit\":{\"type\":\"number\"}}}}}}",
                                        "fe_metadata": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"definitions\":{},\"properties\":{\"records\":{\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"customerNumber\":{\"type\":\"integer\"},\"customerName\":{\"type\":\"string\"},\"contactLastName\":{\"type\":\"string\"},\"contactFirstName\":{\"type\":\"string\"},\"phone\":{\"type\":\"string\"},\"addressLine1\":{\"type\":\"string\"},\"addressLine2\":{\"type\":\"string\"},\"city\":{\"type\":\"string\"},\"state\":{\"type\":\"string\"},\"postalCode\":{\"type\":\"string\"},\"country\":{\"type\":\"string\"},\"salesRepEmployeeNumber\":{\"type\":\"integer\"},\"creditLimit\":{\"type\":\"number\"}}}}}}"
                                    }
                                }
                            },
                            "feSchemaMap": {}
                        }
                    },
                    {
                        "id": "MySQLLogMessage",
                        "name": "MySQLLogMessage",
                        "description": "Simple Log Message Activity",
                        "activity": {
                            "ref": "#log",
                            "input": {
                                "Log Level": "INFO",
                                "flowInfo": false,
                                "message": "=utility.renderJSON($activity[MySQLQuery].Output.records, boolean.false())",
                                "logLevel": ""
                            }
                        }
                    },
                    {
                        "id": "SalesforceUpsert",
                        "name": "SalesforceUpsert",
                        "description": "Salesforce Upsert Activity",
                        "activity": {
                            "ref": "#upsert",
                            "input": {
                                "connectionName": "conn://5f8db4a0-eab3-11eb-a764-dda70f3bcc25",
                                "objectName": "Contact",
                                "externalIdFieldName": "ContactID__c",
                                "allOrNone": "=boolean.false()",
                                "input": {
                                    "mapping": {
                                        "Contact": {
                                            "records": {
                                                "@foreach($activity[MySQLQuery].Output.records,records)": {
                                                    "LastName": "LastNameFromUpsert",
                                                    "FirstName": "=$loop.contactFirstName",
                                                    "ContactID__c": "=string.tostring($loop.customerNumber)"
                                                }
                                            }
                                        }
                                    }
                                }
                            },
                            "schemas": {
                                "input": {
