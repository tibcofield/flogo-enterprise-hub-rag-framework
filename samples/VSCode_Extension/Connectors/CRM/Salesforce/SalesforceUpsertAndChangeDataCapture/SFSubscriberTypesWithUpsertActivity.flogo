{
    "imports": [
        "github.com/project-flogo/flow",
        "github.com/tibco/wi-mysql/src/app/MySQL/activity/query",
        "github.com/tibco/flogo-general/src/app/General/activity/log",
        "github.com/tibco/wi-salesforce/src/app/Salesforce/activity/upsert",
        "query_1 github.com/tibco/wi-salesforce/src/app/Salesforce/activity/query",
        "github.com/project-flogo/contrib/activity/actreturn",
        "github.com/tibco/flogo-general/src/app/General/trigger/rest",
        "github.com/tibco/wi-salesforce/src/app/Salesforce/trigger/salesforce",
        "git.tibco.com/git/product/ipaas/wi-contrib.git/function/boolean",
        "git.tibco.com/git/product/ipaas/wi-contrib.git/function/utility",
        "github.com/project-flogo/contrib/function/array",
        "github.com/project-flogo/contrib/function/string",
