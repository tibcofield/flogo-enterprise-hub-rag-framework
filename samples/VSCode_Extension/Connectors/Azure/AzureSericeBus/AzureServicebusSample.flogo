{
  "imports": [
    "github.com/project-flogo/flow",
    "github.com/tibco/wi-azservicebus/src/app/AzureServiceBus/activity/publish",
    "github.com/tibco/flogo-general/src/app/General/activity/log",
    "github.com/project-flogo/contrib/activity/actreturn",
    "github.com/tibco/wi-azservicebus/src/app/AzureServiceBus/trigger/queuereceiver",
    "github.com/tibco/wi-azservicebus/src/app/AzureServiceBus/trigger/topicsubscriber",
    "github.com/tibco/flogo-general/src/app/General/trigger/rest",
    "github.com/project-flogo/contrib/function/string",
    "github.com/tibco/wi-azservicebus/src/app/AzureServiceBus/connector/connection"
  ],
  "name": "AzureServicebusSample",
  "description": "AZSB app with AZSB pub activity,Queue Receiver & Topic Subscriber",
  "version": "1.0.0",
  "type": "flogo:app",
  "appModel": "1.1.1",
  "tags": [],
  "triggers": [
    {
      "ref": "#queuereceiver",
      "name": "azservicebus-queuereceiver-trigger",
      "description": "",
      "settings": {
        "azservicebusConnection": "conn://2c7b8ee0-04a6-11ec-8a2c-15399fb5e75c"
      },
      "id": "AzureServiceBusQueueReceiver",
      "handlers": [
        {
          "description": "This flow describes how Queue receiver are receiving a message from QueueÂ  using Queue Receiver Trigger",
          "settings": {
            "queue": "testazure",
            "deadletter": false,
            "sessionId": "",
            "receiveMode": "ReceiveAndDelete",
            "Timeout": 0,
            "Count": 0,
            "Interval": 0,
            "valueType": "String"
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:QueueReceiver"
            },
            "input": {
              "output": {
                "mapping": {
                  "messageString": "=$.output.messageString"
                }
              }
            }
          },
          "schemas": {
            "output": {
              "output": {
                "type": "json",
                "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"definitions\":{},\"properties\":{\"messageString\":{\"type\":\"string\"},\"brokerProperties\":{\"type\":\"object\",\"properties\":{\"ContentType\":{\"type\":\"string\"},\"CorrelationId\":{\"type\":\"string\"},\"Label\":{\"type\":\"string\"},\"PartitionKey\":{\"type\":\"string\"},\"ReplyTo\":{\"type\":\"string\"},\"SessionId\":{\"type\":\"string\"},\"TimeToLive\":{\"type\":\"integer\"},\"To\":{\"type\":\"string\"},\"DeliveryCount\":{\"type\":\"integer\"}}}}}",
                "fe_metadata": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"definitions\":{},\"properties\":{\"messageString\":{\"type\":\"string\"},\"brokerProperties\":{\"type\":\"object\",\"properties\":{\"ContentType\":{\"type\":\"string\"},\"CorrelationId\":{\"type\":\"string\"},\"Label\":{\"type\":\"string\"},\"PartitionKey\":{\"type\":\"string\"},\"ReplyTo\":{\"type\":\"string\"},\"SessionId\":{\"type\":\"string\"},\"TimeToLive\":{\"type\":\"integer\"},\"To\":{\"type\":\"string\"},\"DeliveryCount\":{\"type\":\"integer\"}}}}}"
              }
            }
          },
          "name": "QueueReceiver"
        }
      ]
    },
    {
      "ref": "#topicsubscriber",
      "name": "azservicebus-topicsubscriber-trigger",
      "description": "",
      "settings": {
        "azservicebusConnection": "conn://2c7b8ee0-04a6-11ec-8a2c-15399fb5e75c"
      },
      "id": "AzureServiceBusTopicSubscriber",
      "handlers": [
        {
          "description": "This Flow describes how Topics subscriber are subscribed a message in specific subscriber using Topic Subscriber Trigger",
          "settings": {
            "topic": "azuretopic",
            "deadletter": false,
            "subscriptionName": "test1",
            "sessionId": "",
            "receiveMode": "ModePeekLock",
            "Timeout": 0,
            "Count": 0,
            "Interval": 0,
            "valueType": "String"
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:TopicSubscriber"
            },
            "input": {
              "output": {
                "mapping": {
                  "messageString": "=$.output.messageString"
                }
              }
            }
          },
          "schemas": {
            "output": {
              "output": {
                "type": "json",
                "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"definitions\":{},\"properties\":{\"messageString\":{\"type\":\"string\"},\"brokerProperties\":{\"type\":\"object\",\"properties\":{\"ContentType\":{\"type\":\"string\"},\"CorrelationId\":{\"type\":\"string\"},\"Label\":{\"type\":\"string\"},\"PartitionKey\":{\"type\":\"string\"},\"ReplyTo\":{\"type\":\"string\"},\"SessionId\":{\"type\":\"string\"},\"TimeToLive\":{\"type\":\"integer\"},\"To\":{\"type\":\"string\"},\"DeliveryCount\":{\"type\":\"integer\"}}}}}",
                "fe_metadata": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"definitions\":{},\"properties\":{\"messageString\":{\"type\":\"string\"},\"brokerProperties\":{\"type\":\"object\",\"properties\":{\"ContentType\":{\"type\":\"string\"},\"CorrelationId\":{\"type\":\"string\"},\"Label\":{\"type\":\"string\"},\"PartitionKey\":{\"type\":\"string\"},\"ReplyTo\":{\"type\":\"string\"},\"SessionId\":{\"type\":\"string\"},\"TimeToLive\":{\"type\":\"integer\"},\"To\":{\"type\":\"string\"},\"DeliveryCount\":{\"type\":\"integer\"}}}}}"
              }
            }
          },
          "name": "TopicSubscriber"
        }
      ]
    },
    {
      "ref": "#rest",
      "name": "tibco-wi-rest",
      "description": "Simple REST Trigger",
      "settings": {
        "port": 9999,
        "APISpecUpdate": false,
        "swagger": "",
        "swaggerVersion": "v2",
        "apiVersion": "1.0.0",
        "secureConnection": false,
        "serverKey": "",
        "caCertificate": ""
      },
      "id": "ReceiveHTTPMessage",
      "handlers": [
        {
          "description": "This flow describes how message are getting published through Queue and Topic entity using Azure Service Bus Publish Activity",
          "settings": {
            "Method": "POST",
            "reqType": "application/json",
            "Path": "/publisher",
            "OutputValidation": false
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:Publisher"
            },
            "input": {
              "body": {
                "mapping": {
                  "QueueMessage": "=$.body.QueueMessage",
                  "TopicMessage": "=$.body.TopicMessage"
                }
              }
            },
            "output": {
              "data": {
                "mapping": {
                  "Output": "=$.data.Output"
                }
              }
            }
          },
          "reply": {
            "code": 200,
            "configureResponseCodes": false,
            "message": {}
          },
          "schemas": {
            "reply": {
              "data": {
                "type": "json",
                "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"Output\":{\"type\":\"string\"}}}",
                "fe_metadata": "{\n    \"Output\":\"\"\n}"
              },
              "responseBody": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}",
                "fe_metadata": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}"
              }
            },
            "output": {
              "headers": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"Accept\":{\"type\":\"string\",\"visible\":false},\"Accept-Charset\":{\"type\":\"string\",\"visible\":false},\"Accept-Encoding\":{\"type\":\"string\",\"visible\":false},\"Content-Type\":{\"type\":\"string\",\"visible\":false},\"Content-Length\":{\"type\":\"string\",\"visible\":false},\"Connection\":{\"type\":\"string\",\"visible\":false},\"Cookie\":{\"type\":\"string\",\"visible\":false},\"Pragma\":{\"type\":\"string\",\"visible\":false}},\"required\":[]}",
                "fe_metadata": "[{\"parameterName\":\"Accept\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Charset\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Encoding\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Type\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Length\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Connection\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Cookie\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Pragma\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false}]"
              },
              "body": {
                "type": "json",
                "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"QueueMessage\":{\"type\":\"string\"},\"TopicMessage\":{\"type\":\"string\"}}}",
                "fe_metadata": "{\n    \"QueueMessage\":\" \",\n    \"TopicMessage\":\" \"\n}"
              }
            }
          },
          "name": "Publisher"
        }
      ]
    }
  ],
  "resources": [
    {
      "id": "flow:Publisher",
      "data": {
        "name": "Publisher",
        "description": "This flow describes how message are getting published through Queue and Topic entity using Azure Service Bus Publish Activity",
        "links": [
          {
            "id": 1,
            "from": "AzureServiceBusPublish",
            "to": "AzureServiceBusPublish1",
            "type": "label",
            "label": "AzureServiceBusPublish to AzureServiceBusPublish1"
          },
          {
            "id": 2,
            "from": "AzureServiceBusPublish1",
            "to": "LogMessage",
            "type": "label",
            "label": "AzureServiceBusPublish1 to LogMessage"
          },
          {
            "id": 3,
            "from": "LogMessage",
            "to": "Return",
            "type": "label",
            "label": "LogMessage to Return"
          }
        ],
        "tasks": [
          {
            "id": "AzureServiceBusPublish",
            "name": "AzureServiceBusPublish",
            "description": "AzureServiceBus Publish Activity",
            "activity": {
              "ref": "#publish",
              "input": {
                "Connection": "conn://2c7b8ee0-04a6-11ec-8a2c-15399fb5e75c",
                "entityType": "Queue",
                "Timeout": 0,
                "entityName": "",
                "input": {
                  "mapping": {
                    "parameters": {
                      "queueName": "testazure",
                      "messageString": "=$flow.body.QueueMessage"
                    }
                  }
                }
              },
              "schemas": {
                "input": {
                  "input": {
                    "type": "json",
                    "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"definitions\":{},\"properties\":{\"parameters\":{\"$id\":\"http://example.com/example.json\",\"type\":\"object\",\"definitions\":{},\"$schema\":\"http://json-schema.org/draft-07/schema#\",\"additionalProperties\":false,\"properties\":{\"queueName\":{\"type\":\"string\"},\"messageString\":{\"type\":\"string\"},\"brokerProperties\":{\"type\":\"object\",\"properties\":{\"ContentType\":{\"type\":\"string\"},\"CorrelationId\":{\"type\":\"string\"},\"Label\":{\"type\":\"string\"},\"PartitionKey\":{\"type\":\"string\"},\"ReplyTo\":{\"type\":\"string\"},\"SessionId\":{\"type\":\"string\"},\"TimeToLive\":{\"type\":\"integer\",\"minimum\":0},\"ScheduledEnqueueTimeUtc\":{\"type\":\"string\"},\"To\":{\"type\":\"string\"}}}},\"required\":[\"queueName\",\"messageString\"]}}}",
                    "fe_metadata": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"definitions\":{},\"properties\":{\"parameters\":{\"$id\":\"http://example.com/example.json\",\"type\":\"object\",\"definitions\":{},\"$schema\":\"http://json-schema.org/draft-07/schema#\",\"additionalProperties\":false,\"properties\":{\"queueName\":{\"type\":\"string\"},\"messageString\":{\"type\":\"string\"},\"brokerProperties\":{\"type\":\"object\",\"properties\":{\"ContentType\":{\"type\":\"string\"},\"CorrelationId\":{\"type\":\"string\"},\"Label\":{\"type\":\"string\"},\"PartitionKey\":{\"type\":\"string\"},\"ReplyTo\":{\"type\":\"string\"},\"SessionId\":{\"type\":\"string\"},\"TimeToLive\":{\"type\":\"integer\",\"minimum\":0},\"ScheduledEnqueueTimeUtc\":{\"type\":\"string\"},\"To\":{\"type\":\"string\"}}}},\"required\":[\"queueName\",\"messageString\"]}}}"
                  }
                },
                "output": {
                  "output": {
                    "type": "json",
                    "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"definitions\":{},\"properties\":{\"responseMessage\":{\"type\":\"string\"}}}",
                    "fe_metadata": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"definitions\":{},\"properties\":{\"responseMessage\":{\"type\":\"string\"}}}"
                  }
                }
              },
              "feSchemaMap": {}
            }
          },
          {
            "id": "AzureServiceBusPublish1",
            "name": "AzureServiceBusPublish1",
            "description": "AzureServiceBus Publish Activity",
            "activity": {
              "ref": "#publish",
              "input": {
                "Connection": "conn://2c7b8ee0-04a6-11ec-8a2c-15399fb5e75c",
                "entityType": "Topic",
                "Timeout": 0,
                "entityName": "",
                "input": {
                  "mapping": {
                    "parameters": {
                      "topicName": "azuretopic",
                      "messageString": "=$flow.body.TopicMessage"
                    }
                  }
                }
              },
              "schemas": {
                "input": {
                  "input": {
                    "type": "json",
                    "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"definitions\":{},\"properties\":{\"parameters\":{\"$id\":\"http://example.com/example.json\",\"type\":\"object\",\"definitions\":{},\"$schema\":\"http://json-schema.org/draft-07/schema#\",\"additionalProperties\":false,\"properties\":{\"topicName\":{\"type\":\"string\"},\"messageString\":{\"type\":\"string\"},\"brokerProperties\":{\"type\":\"object\",\"properties\":{\"ContentType\":{\"type\":\"string\"},\"CorrelationId\":{\"type\":\"string\"},\"Label\":{\"type\":\"string\"},\"PartitionKey\":{\"type\":\"string\"},\"ReplyTo\":{\"type\":\"string\"},\"SessionId\":{\"type\":\"string\"},\"TimeToLive\":{\"type\":\"integer\",\"minimum\":0},\"ScheduledEnqueueTimeUtc\":{\"type\":\"string\"},\"To\":{\"type\":\"string\"}}}},\"required\":[\"topicName\",\"messageString\"]}}}",
                    "fe_metadata": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"definitions\":{},\"properties\":{\"parameters\":{\"$id\":\"http://example.com/example.json\",\"type\":\"object\",\"definitions\":{},\"$schema\":\"http://json-schema.org/draft-07/schema#\",\"additionalProperties\":false,\"properties\":{\"topicName\":{\"type\":\"string\"},\"messageString\":{\"type\":\"string\"},\"brokerProperties\":{\"type\":\"object\",\"properties\":{\"ContentType\":{\"type\":\"string\"},\"CorrelationId\":{\"type\":\"string\"},\"Label\":{\"type\":\"string\"},\"PartitionKey\":{\"type\":\"string\"},\"ReplyTo\":{\"type\":\"string\"},\"SessionId\":{\"type\":\"string\"},\"TimeToLive\":{\"type\":\"integer\",\"minimum\":0},\"ScheduledEnqueueTimeUtc\":{\"type\":\"string\"},\"To\":{\"type\":\"string\"}}}},\"required\":[\"topicName\",\"messageString\"]}}}"
                  }
                },
                "output": {
                  "output": {
                    "type": "json",
                    "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"definitions\":{},\"properties\":{\"responseMessage\":{\"type\":\"string\"}}}",
                    "fe_metadata": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"definitions\":{},\"properties\":{\"responseMessage\":{\"type\":\"string\"}}}"
                  }
                }
              },
              "feSchemaMap": {}
            }
          },
          {
            "id": "LogMessage",
            "name": "LogMessage",
            "description": "Simple Log Message Activity",
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": false,
                "message": "=string.concat(\"The published entities are \", $activity[AzureServiceBusPublish].output.responseMessage, $activity[AzureServiceBusPublish1].output.responseMessage)"
              }
            }
          },
          {
            "id": "Return",
            "name": "Return",
            "description": "Simple Return Activity",
            "activity": {
              "ref": "#actreturn",
              "settings": {
                "mappings": {
                  "data": {
                    "mapping": {
                      "Output": "The messages are published successfully!!!!!!"
                    }
                  }
                }
              }
            }
          }
        ],
        "fe_metadata": "eyJBenVyZVNlcnZpY2VCdXNQdWJsaXNoIjp7IngiOjUwLCJ5Ijo1MH0sIkF6dXJlU2VydmljZUJ1c1B1Ymxpc2gxIjp7IngiOjI1MCwieSI6NTB9LCJMb2dNZXNzYWdlIjp7IngiOjQ1MCwieSI6NTB9LCJSZXR1cm4iOnsieCI6NjUwLCJ5Ijo1MH19",
        "metadata": {
          "input": [
            {
              "name": "headers",
              "type": "object",
              "schema": {
                "type": "json",
                "value": "{\"Accept\":{\"type\":\"string\",\"visible\":false},\"Accept-Charset\":{\"type\":\"string\",\"visible\":false},\"Accept-Encoding\":{\"type\":\"string\",\"visible\":false},\"Content-Type\":{\"type\":\"string\",\"visible\":false},\"Content-Length\":{\"type\":\"string\",\"visible\":false},\"Connection\":{\"type\":\"string\",\"visible\":false},\"Cookie\":{\"type\":\"string\",\"visible\":false},\"Pragma\":{\"type\":\"string\",\"visible\":false}}"
              }
            },
            {
              "name": "body",
              "type": "object",
              "schema": {
                "type": "json",
                "value": "{\"QueueMessage\":{\"type\":\"string\"},\"TopicMessage\":{\"type\":\"string\"}}"
              }
            }
          ],
          "output": [
            {
              "name": "code",
              "type": "integer"
            },
            {
              "name": "data",
              "type": "object",
              "schema": {
                "type": "json",
                "value": "{\"Output\":{\"type\":\"string\"}}"
              }
            }
          ],
          "fe_metadata": {
            "input": "{\"type\":\"object\",\"title\":\"ReceiveHTTPMessage\",\"properties\":{\"headers\":{\"type\":\"object\",\"properties\":{\"Accept\":{\"type\":\"string\",\"visible\":false},\"Accept-Charset\":{\"type\":\"string\",\"visible\":false},\"Accept-Encoding\":{\"type\":\"string\",\"visible\":false},\"Content-Type\":{\"type\":\"string\",\"visible\":false},\"Content-Length\":{\"type\":\"string\",\"visible\":false},\"Connection\":{\"type\":\"string\",\"visible\":false},\"Cookie\":{\"type\":\"string\",\"visible\":false},\"Pragma\":{\"type\":\"string\",\"visible\":false}},\"required\":[]},\"body\":{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"QueueMessage\":{\"type\":\"string\"},\"TopicMessage\":{\"type\":\"string\"}}}}}",
            "output": "{\"type\":\"object\",\"title\":\"Inputs\",\"properties\":{\"code\":{\"type\":\"integer\",\"required\":false},\"data\":{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"Output\":{\"type\":\"string\"}}}},\"required\":[]}"
          }
        },
        "explicitReply": true
      }
    },
