            "name": "Return",
            "description": "Return sales summary as JSON resource content",
            "activity": {
              "ref": "#actreturn",
              "settings": {
                "mappings": {
                  "response": {
                    "mapping": {
                      "textResourceContents": [
                        {
                          "uri": "sales://summary",
                          "mimeType": "application/json",
                          "text": "{\"sales_summary\":{\"total_revenue\":\"$593,463.00\",\"total_transactions\":10,\"period\":\"2025-01 to 2025-05\",\"top_products\":[{\"product_name\":\"mjolnir hammer\",\"units_sold\":1,\"revenue\":\"$199,999.00\"},{\"product_name\":\"magic lasso\",\"units_sold\":1,\"revenue\":\"$143,953.00\"},{\"product_name\":\"vibranium shield\",\"units_sold\":1,\"revenue\":\"$139,503.00\"}],\"top_customers\":[{\"customer_name\":\"thor odinson\",\"transactions\":1,\"total_spend\":\"$199,999.00\"},{\"customer_name\":\"diana prince\",\"transactions\":1,\"total_spend\":\"$143,953.00\"},{\"customer_name\":\"bruce wayne\",\"transactions\":2,\"total_spend\":\"$26,746.00\"}]}}"
                        }
                      ]
                    }
                  }
                }
              }
            }
          }
        ],
        "fe_metadata": "eyJTdGFydEFjdGl2aXR5Ijp7IngiOjUwLCJ5Ijo1MH0sIlJldHVybiI6eyJ4IjoyNTAsInkiOjE1MH19",
