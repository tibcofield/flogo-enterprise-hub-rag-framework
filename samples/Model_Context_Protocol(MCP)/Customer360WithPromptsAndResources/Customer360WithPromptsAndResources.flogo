    {
      "id": "flow:Analyze_Customer_Sales_Prompt",
      "data": {
        "name": "Analyze_Customer_Sales_Prompt",
        "description": "Prompt that returns a structured sales analysis instruction for a named customer and period. Returns role and content message pairs to start the analysis conversation.",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "LogStart",
            "type": "label",
            "label": "Start"
          },
          {
            "id": 2,
            "from": "LogStart",
            "to": "Return",
            "type": "label",
            "label": "Return"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "NoOp Activity",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "LogStart",
            "name": "LogStart",
            "description": "Log prompt invocation",
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": false,
                "message": "=string.concat(\"Analyze_Customer_Sales_Prompt invoked: customer=\", coerce.toString($flow.arguments.customer_name), \" period=\", coerce.toString($flow.arguments.period))",
                "logLevel": ""
              }
            }
          },
          {
            "id": "Return",
            "name": "Return",
            "description": "Return prompt messages for customer sales analysis",
            "activity": {
              "ref": "#actreturn",
              "settings": {
                "mappings": {
                  "response": {
                    "mapping": {
                      "description": "=string.concat(\"Sales analysis for \", coerce.toString($flow.arguments.customer_name), \" - \", coerce.toString($flow.arguments.period))",
                      "messages": [
                        {
                          "role": "user",
                          "content": "=string.concat(\"You are a Customer 360 sales analyst. Using the data available from the GetCustomers, GetProducts, and GetSales tools, please perform a comprehensive sales analysis for the customer named '\", coerce.toString($flow.arguments.customer_name), \"' covering the period '\", coerce.toString($flow.arguments.period), \"'.\\n\\nYour analysis should include:\\n1. Total number of transactions and total spend for this customer during the period.\\n2. A breakdown of all products purchased, including product name, unit price and quantity.\\n3. The customer's average order value compared to the overall customer average.\\n4. The top-selling product category this customer has purchased from.\\n5. Any noticeable purchase trends or patterns (e.g. repeat purchases, increasing spend, seasonal behaviour).\\n6. A one-paragraph executive summary.\\n\\nCall the necessary tools to retrieve the data, then present the analysis in a clear, structured format.\")"
                        }
                      ]
                    }
                  }
                }
              }
            }
          }
        ],
        "fe_metadata": "eyJTdGFydEFjdGl2aXR5Ijp7IngiOjUwLCJ5Ijo1MH0sIkxvZ1N0YXJ0Ijp7IngiOjIxMywieSI6NDJ9LCJSZXR1cm4iOnsieCI6NDQ3LCJ5Ijo0OH19",
        "metadata": {
          "input": [
            {
              "name": "arguments",
              "type": "object",
              "schema": {
                "type": "json",
                "value": "{\"customer_name\":{\"type\":\"string\",\"description\":\"The full name of the customer\"},\"period\":{\"type\":\"string\",\"description\":\"The sales period, e.g. Q1 2025\"}}"
              }
            },
            {
              "name": "httpHeaders",
              "type": "params"
            }
          ],
          "output": [
            {
              "name": "response",
              "type": "object",
              "schema": {
                "type": "json",
                "value": "{\"description\":{\"type\":\"string\"},\"messages\":{\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"role\":{\"type\":\"string\"},\"content\":{\"type\":\"string\"}},\"required\":[\"role\",\"content\"]}},\"error\":{\"type\":\"string\"}}"
              }
            }
          ],
          "fe_metadata": {
            "input": "{\"type\":\"object\",\"title\":\"MCPServer\",\"properties\":{\"arguments\":{\"type\":\"object\",\"properties\":{\"customer_name\":{\"type\":\"string\",\"description\":\"The full name of the customer\"},\"period\":{\"type\":\"string\",\"description\":\"The sales period, e.g. Q1 2025\"}},\"required\":[\"customer_name\",\"period\"]},\"httpHeaders\":{\"type\":\"params\"}}}",
            "output": "{\"type\":\"object\",\"title\":\"Inputs\",\"properties\":{\"response\":{\"type\":\"object\",\"properties\":{\"description\":{\"type\":\"string\"},\"messages\":{\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"role\":{\"type\":\"string\"},\"content\":{\"type\":\"string\"}},\"required\":[\"role\",\"content\"]}},\"error\":{\"type\":\"string\"}}}},\"required\":[\"response\"]}"
          }
        }
      }
    },
    {
      "id": "flow:Cross_Sell_Recommendation_Prompt",
      "data": {
        "name": "Cross_Sell_Recommendation_Prompt",
        "description": "Prompt that returns a cross-sell recommendation instruction for a named customer. Guides the AI to compare purchase history against the catalog and suggest complementary products.",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "LogStart",
            "type": "label",
            "label": "Start"
          },
          {
            "id": 2,
            "from": "LogStart",
            "to": "Return",
            "type": "label",
            "label": "Return"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "NoOp Activity",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "LogStart",
            "name": "LogStart",
            "description": "Log prompt invocation",
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": false,
                "message": "=string.concat(\"Cross_Sell_Recommendation_Prompt invoked: customer=\", coerce.toString($flow.arguments.customer_name))",
                "logLevel": ""
              }
            }
          },
          {
            "id": "Return",
            "name": "Return",
            "description": "Return prompt messages for cross-sell recommendation",
            "activity": {
              "ref": "#actreturn",
              "settings": {
                "mappings": {
                  "response": {
                    "mapping": {
                      "description": "=string.concat(\"Cross-sell recommendations for \", coerce.toString($flow.arguments.customer_name))",
                      "messages": [
                        {
                          "role": "user",
                          "content": "=string.concat(\"You are a Customer 360 product recommendation engine. Using the GetCustomers, GetProducts, and GetSales tools, identify personalised cross-sell opportunities for the customer named '\", coerce.toString($flow.arguments.customer_name), \"'.\\n\\nFollow these steps:\\n1. Retrieve all sales transactions for this customer using GetSales and filter by their name.\\n2. Retrieve the complete product catalog using GetProducts (or the products://catalog resource if available).\\n3. Identify which products the customer has NEVER purchased.\\n4. From those unpurchased products, recommend up to 3 that are most complementary to what the customer has already bought (consider product category, price range, and typical bundle patterns).\\n5. For each recommended product provide:\\n   - Product name and MSRP\\n   - Why it complements the customer's existing purchases\\n   - A personalised one-sentence pitch\\n\\nPresent the recommendations in a structured, sales-ready format.\")"
                        }
                      ]
                    }
                  }
                }
              }
            }
          }
        ],
        "fe_metadata": "eyJTdGFydEFjdGl2aXR5Ijp7IngiOjUwLCJ5Ijo1MH0sIkxvZ1N0YXJ0Ijp7IngiOjI0NSwieSI6NDV9LCJSZXR1cm4iOnsieCI6NDYwLCJ5Ijo0OH19",
        "metadata": {
          "input": [
            {
              "name": "arguments",
              "type": "object",
              "schema": {
                "type": "json",
                "value": "{\"customer_name\":{\"type\":\"string\",\"description\":\"The full name of the customer\"}}"
              }
            },
            {
              "name": "httpHeaders",
              "type": "params"
            }
          ],
          "output": [
            {
              "name": "response",
              "type": "object",
              "schema": {
                "type": "json",
                "value": "{\"description\":{\"type\":\"string\"},\"messages\":{\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"role\":{\"type\":\"string\"},\"content\":{\"type\":\"string\"}},\"required\":[\"role\",\"content\"]}},\"error\":{\"type\":\"string\"}}"
              }
            }
          ],
