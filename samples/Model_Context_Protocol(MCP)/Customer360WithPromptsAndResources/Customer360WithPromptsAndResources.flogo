    {
      "id": "flow:Product_Catalog_Resource",
      "data": {
        "name": "Product_Catalog_Resource",
        "description": "Static resource returning the full product catalog as JSON. The AI client reads this once as context to reduce repeated tool calls.",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "Return",
            "type": "label",
            "label": "Start to Return"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "NoOp Activity",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "Return",
            "name": "Return",
            "description": "Return product catalog as JSON resource content",
            "activity": {
              "ref": "#actreturn",
              "settings": {
                "mappings": {
                  "response": {
                    "mapping": {
                      "textResourceContents": [
                        {
                          "uri": "products://catalog",
                          "mimeType": "application/json",
