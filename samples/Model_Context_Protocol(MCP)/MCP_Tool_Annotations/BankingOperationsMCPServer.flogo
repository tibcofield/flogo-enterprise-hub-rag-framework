            "id": "Return",
            "name": "Return",
            "description": "Returns closure confirmation. Replace with account lifecycle API in production.",
            "activity": {
              "ref": "#actreturn",
              "settings": {
                "mappings": {
                  "response": {
                    "@conditional": [
                      {
                        "$flow.arguments.account_id != '' && coerce.toString($flow.arguments.confirm) == 'true'": {
                          "data": "=string.concat(\"Account closed | Account: \",$flow.arguments.account_id,\" | Status: CLOSED | Closed At: 2026-04-14T09:30:00Z | Reason: \",coerce.toString($flow.arguments.reason),\" | WARNING: Destructive — this action cannot be reversed without manual bank operations intervention. Idempotent — closing an already-closed account returns this same result.\")"
                        }
                      },
                      {
                        "$flow.arguments.account_id != '' && coerce.toString($flow.arguments.confirm) != 'true'": {
                          "error": "confirm must be set to true to authorise this irreversible destructive operation"
                        }
                      },
                      {
                        "@otherwise": {
                          "error": "account_id and confirm=true are required"
                        }
                      }
                    ]
                  }
                }
              }
            }
          }
        ],
