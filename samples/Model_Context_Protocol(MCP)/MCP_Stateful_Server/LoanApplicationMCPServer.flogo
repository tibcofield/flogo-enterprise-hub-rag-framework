    {
      "id": "flow:submit_application_flow",
      "data": {
        "name": "submit_application_flow",
        "description": "Step 4: Reads session state and submits to loan origination API. Not idempotent.",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "ReadFinalState",
            "type": "label",
            "label": "StartActivity to ReadFinalState"
          },
          {
            "id": 2,
            "from": "ReadFinalState",
            "to": "Return",
            "type": "label",
            "label": "ReadFinalState to Return"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "NoOp Activity",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "ReadFinalState",
            "name": "ReadFinalState",
            "description": "Reads complete session state for final submission. Replace with DB + external API in production.",
            "activity": {
              "ref": "#read",
              "input": {
                "readAs": "Text",
                "compress": "None",
                "input": {
                  "mapping": {
                    "fileName": "=string.concat($property[\"session_state_dir\"],\"/session_\",coerce.toString($flow.arguments.application_ref),\".json\")"
                  }
                }
              },
              "schemas": {
                "input": {
                  "input": {
                    "type": "json",
                    "value": "{\"properties\":{\"fileName\":{\"type\":\"string\"}},\"required\":[\"fileName\"],\"type\":\"object\"}",
                    "fe_metadata": "{\"properties\":{\"fileName\":{\"type\":\"string\"}},\"required\":[\"fileName\"],\"type\":\"object\"}"
                  }
                },
                "output": {
                  "output": {
                    "type": "json",
                    "value": "{\"properties\":{\"fileMetadata\":{\"properties\":{\"fullPath\":{\"type\":\"string\"},\"name\":{\"type\":\"string\"},\"size\":{\"type\":\"number\"},\"mode\":{\"type\":\"string\"},\"modTime\":{\"type\":\"string\",\"format\":\"date-time\"},\"isDir\":{\"type\":\"boolean\"}},\"type\":\"object\"},\"fileContent\":{\"properties\":{\"textContent\":{\"type\":\"string\"}},\"type\":\"object\"}},\"type\":\"object\"}",
                    "fe_metadata": "{\"properties\":{\"fileMetadata\":{\"properties\":{\"fullPath\":{\"type\":\"string\"},\"name\":{\"type\":\"string\"},\"size\":{\"type\":\"number\"},\"mode\":{\"type\":\"string\"},\"modTime\":{\"type\":\"string\",\"format\":\"date-time\"},\"isDir\":{\"type\":\"boolean\"}},\"type\":\"object\"},\"fileContent\":{\"properties\":{\"textContent\":{\"type\":\"string\"}},\"type\":\"object\"}},\"type\":\"object\"}"
                  }
                }
              },
              "feSchemaMap": {}
            }
          },
          {
            "id": "Return",
            "name": "Return",
            "description": "Returns unique tracking number. Not idempotent.",
            "activity": {
              "ref": "#actreturn",
              "settings": {
                "mappings": {
                  "response": {
                    "@conditional": [
                      {
                        "$flow.arguments.application_ref != '' && coerce.toString($flow.arguments.applicant_consent) == 'true'": {
                          "data": "=string.concat(\"=== APPLICATION SUBMITTED === | Application Ref: \",$flow.arguments.application_ref,\" | Tracking Number: TRK-\",$flow.arguments.application_ref,\"-093042 | Session State Submitted: \",$activity[ReadFinalState].output.fileContent.textContent,\" | Status: SUBMITTED_FOR_UNDERWRITING | Estimated Decision: 3-5 business days | Confirmation email sent to applicant | Next step: Use Tracking Number TRK-\",$flow.arguments.application_ref,\"-093042 to check application status with the bank. NOT idempotent — do not submit again.\")"
                        }
                      },
                      {
                        "$flow.arguments.application_ref != '' && coerce.toString($flow.arguments.applicant_consent) != 'true'": {
                          "error": "applicant_consent must be true — the applicant must review and consent before this application can be submitted"
                        }
                      },
                      {
                        "@otherwise": {
                          "error": "application_ref and applicant_consent=true are required"
                        }
                      }
                    ]
                  }
                }
              }
            }
          }
        ],
        "fe_metadata": "eyJTdGFydEFjdGl2aXR5Ijp7IngiOjUwLCJ5Ijo1MH0sIlJlYWRGaW5hbFN0YXRlIjp7IngiOjIyMywieSI6NDl9LCJSZXR1cm4iOnsieCI6NDQ2LCJ5Ijo1NH19",
        "metadata": {
