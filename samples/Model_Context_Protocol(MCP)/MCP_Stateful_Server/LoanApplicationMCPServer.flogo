    {
      "id": "flow:review_application_flow",
      "data": {
        "name": "review_application_flow",
        "description": "Step 3: Read-only review of accumulated session state.",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "ReadApplicationState",
            "type": "label",
            "label": "StartActivity to ReadApplicationState"
          },
          {
            "id": 2,
            "from": "ReadApplicationState",
            "to": "Return",
            "type": "label",
            "label": "ReadApplicationState to Return"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "NoOp Activity",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "ReadApplicationState",
            "name": "ReadApplicationState",
            "description": "Reads full accumulated session state. Replace with DB/cache in production.",
            "activity": {
              "ref": "#read",
              "input": {
                "readAs": "Text",
                "compress": "None",
                "input": {
                  "mapping": {
                    "fileName": "=string.concat($property[\"session_state_dir\"],\"/session_\",coerce.toString($flow.arguments.application_ref),\".json\")"
                  }
                }
              },
              "schemas": {
                "input": {
                  "input": {
                    "type": "json",
                    "value": "{\"properties\":{\"fileName\":{\"type\":\"string\"}},\"required\":[\"fileName\"],\"type\":\"object\"}",
                    "fe_metadata": "{\"properties\":{\"fileName\":{\"type\":\"string\"}},\"required\":[\"fileName\"],\"type\":\"object\"}"
                  }
                },
                "output": {
                  "output": {
                    "type": "json",
                    "value": "{\"properties\":{\"fileMetadata\":{\"properties\":{\"fullPath\":{\"type\":\"string\"},\"name\":{\"type\":\"string\"},\"size\":{\"type\":\"number\"},\"mode\":{\"type\":\"string\"},\"modTime\":{\"type\":\"string\",\"format\":\"date-time\"},\"isDir\":{\"type\":\"boolean\"}},\"type\":\"object\"},\"fileContent\":{\"properties\":{\"textContent\":{\"type\":\"string\"}},\"type\":\"object\"}},\"type\":\"object\"}",
                    "fe_metadata": "{\"properties\":{\"fileMetadata\":{\"properties\":{\"fullPath\":{\"type\":\"string\"},\"name\":{\"type\":\"string\"},\"size\":{\"type\":\"number\"},\"mode\":{\"type\":\"string\"},\"modTime\":{\"type\":\"string\",\"format\":\"date-time\"},\"isDir\":{\"type\":\"boolean\"}},\"type\":\"object\"},\"fileContent\":{\"properties\":{\"textContent\":{\"type\":\"string\"}},\"type\":\"object\"}},\"type\":\"object\"}"
                  }
                }
              },
              "feSchemaMap": {}
            }
          },
          {
            "id": "Return",
            "name": "Return",
            "description": "Returns full application summary for review.",
            "activity": {
              "ref": "#actreturn",
              "settings": {
                "mappings": {
                  "response": {
                    "@conditional": [
                      {
                        "$flow.arguments.application_ref != ''": {
                          "data": "=string.concat(\"=== LOAN APPLICATION REVIEW === | Application Ref: \",$flow.arguments.application_ref,\" | Session State: \",$activity[ReadApplicationState].output.fileContent.textContent,\" | --- | If all details are correct, call submit_application with this ref and applicant_consent=true to finalise. To update financial details, call submit_financial_profile again (idempotent).\")"
                        }
                      },
                      {
                        "@otherwise": {
                          "error": "application_ref is required"
                        }
                      }
                    ]
                  }
                }
              }
            }
          }
        ],
        "fe_metadata": "eyJTdGFydEFjdGl2aXR5Ijp7IngiOjUwLCJ5Ijo1MH0sIlJlYWRBcHBsaWNhdGlvblN0YXRlIjp7IngiOjIwOCwieSI6NDd9LCJSZXR1cm4iOnsieCI6NDQyLCJ5Ijo1Mn19",
