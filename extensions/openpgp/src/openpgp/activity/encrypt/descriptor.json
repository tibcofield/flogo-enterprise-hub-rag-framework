{
  "name": "encrypt",
  "version": "1.0.0",
  "title": "Encrypt",
  "description": "Activity to encrypt openpgp messages",
  "author": "TIBCO Software Inc.",
  "type": "flogo:activity",
  "ref": "github.com/mmussett/extensions/openpgp/activity/encrypt",
  "display": {
    "category": "openpgp",
    "visible": true,
    "smallIcon": "icons/openpgp-encrypt@2x.png",
    "largeIcon": "icons/openpgp-encrypt@3x.png",
    "description": "This activity encrypts any plaintext string to cyphertext using an openpgp public key"
  },
  "inputs": [
    {
      "name": "plaintext",
      "type": "string",
      "required": true
    },
    {
      "name": "publickey",
      "type": "string",
      "required": true
    }
  ],

  "outputs": [
    {
      "name": "ciphertext",
      "type": "string"
    }
  ]
}
