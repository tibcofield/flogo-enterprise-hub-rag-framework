{
  "name": "decrypt",
  "version": "1.0.0",
  "title": "Decrypt",
  "description": "Activity to decrypt openpgp messages",
  "author": "TIBCO Software Inc.",
  "type": "flogo:activity",
  "ref": "github.com/mmussett/extensions/openpgp/activity/decrypt",
  "display": {
    "category": "openpgp",
    "visible": true,
    "smallIcon": "icons/openpgp-decrypt@2x.png",
    "largeIcon": "icons/openpgp-decrypt@3x.png",
    "description": "This activity decrypts any openpgp ciphertext to plaintext using a private key"
  },
  "inputs": [
    {
      "name": "ciphertext",
      "type": "string",
      "required": true
    },
    {
      "name": "privatekey",
      "type": "string",
      "required": true
    }
  ],

  "outputs": [
    {
      "name": "plaintext",
      "type": "string"
    }
  ]
}
