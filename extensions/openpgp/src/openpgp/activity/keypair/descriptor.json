{
  "name": "keypair",
  "version": "1.0.0",
  "title": "Generate keypair",
  "description": "Generates a key pair",
  "author": "TIBCO Software Inc.",
  "type": "flogo:activity",
  "ref": "github.com/mmussett/extensions/openpgp/activity/keypair",
  "display": {
    "category": "openpgp",
    "visible": true,
    "smallIcon": "icons/openpgp-keypair@2x.png",
    "largeIcon": "icons/openpgp-keypair@3x.png",
    "description": "This activity generates a new openpgp public and private key pair"
  },
  "inputs": [
    {
      "name": "name",
      "type": "string",
      "required": true
    },
    {
      "name": "comment",
      "type": "string",
      "required": true
    },
    {
      "name": "email",
      "type": "string",
      "required": true
    }
  ],

  "outputs": [
    {
      "name": "publicKey",
      "type": "string"
    },
    {
      "name": "privateKey",
      "type": "string"
    }
  ]
}
