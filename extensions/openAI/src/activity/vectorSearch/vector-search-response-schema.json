{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpenAI Vector Store Search Response",
  "description": "Schema for OpenAI vector store search results array",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "attributes": {
        "type": "object",
        "description": "Metadata attributes associated with the document",
        "patternProperties": {
          "^.*$": {
            "type": "object",
            "properties": {
              "OfString": {
                "type": "string",
                "description": "String value of the attribute"
              },
              "OfFloat": {
                "type": "number",
                "description": "Numeric value of the attribute"
              },
              "OfBool": {
                "type": "boolean",
                "description": "Boolean value of the attribute"
              }
            },
            "required": ["OfString", "OfFloat", "OfBool"],
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },
      "content": {
        "type": "array",
        "description": "Array of content chunks from the document",
        "items": {
          "type": "object",
          "properties": {
            "text": {
              "type": "string",
              "description": "The actual text content of the chunk"
            },
            "type": {
              "type": "string",
              "description": "Content type (typically 'text')",
              "enum": ["text"]
            }
          },
          "required": ["text", "type"],
          "additionalProperties": false
        },
        "minItems": 1
      },
      "file_id": {
        "type": "string",
        "description": "OpenAI file identifier",
        "pattern": "^file-[a-zA-Z0-9]+$"
      },
      "filename": {
        "type": "string",
        "description": "Original filename of the document"
      },
      "score": {
        "type": "number",
        "description": "Similarity score for the search result",
        "minimum": 0,
        "maximum": 1
      }
    },
    "required": ["attributes", "content", "file_id", "filename", "score"],
    "additionalProperties": false
  },
  "examples": [
    [
      {
        "attributes": {
          "DocGroup": {
            "OfString": "BusinessWorks",
            "OfFloat": 0,
            "OfBool": false
          },
          "DocType": {
            "OfString": "Concepts Guide",
            "OfFloat": 0,
            "OfBool": false
          },
          "Download URL": {
            "OfString": "https://docs.tibco.com/pub/activematrix_businessworks/6.12.0/doc/pdf/TIB_bwce_6.12.0_installation.pdf?id=15",
            "OfFloat": 0,
            "OfBool": false
          }
        },
        "content": [
          {
            "text": "When the events that trigger the execution of a process occur concurrently, the engine runs the same process multiple times, concurrently, once for each event.",
            "type": "text"
          }
        ],
        "file_id": "file-9G1DQENXabusRV1nQ367e5",
        "filename": "TIB-bwce_6.12_concepts.pdf",
        "score": 0.5750257005398239
      }
    ]
  ]
}