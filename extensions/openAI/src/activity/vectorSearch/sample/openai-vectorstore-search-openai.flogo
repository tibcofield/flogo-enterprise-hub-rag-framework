{
  "imports": [
    "github.com/project-flogo/flow",
    "github.com/project-flogo/contrib/activity/noop",
    "github.com/tibco/flogo-general/src/app/General/activity/sleep",
    "github.com/TIBCOSoftware/flogo-enterprise-hub/extensions/openAI/activity/vectorSearch",
    "github.com/tibco/flogo-general/src/app/General/activity/log",
    "github.com/project-flogo/contrib/activity/actreturn",
    "github.com/tibco/flogo-general/src/app/General/trigger/startuphook",
    "github.com/project-flogo/contrib/function/coerce"
  ],
  "name": "openai-vectorStore-search-openai",
  "description": "",
  "version": "1.0.0",
  "type": "flogo:app",
  "appModel": "1.1.1",
  "tags": [],
  "triggers": [
    {
      "ref": "#startuphook",
      "name": "tibco-appstartup",
      "description": "This trigger allows you to execute flows before other triggers in the application are started. This is useful in initializing application specific tasks.",
      "settings": {},
      "id": "AppStartupTrigger",
      "handlers": [
        {
          "description": "",
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:Vectorstore_search"
            }
          },
          "name": "Vectorstore_search"
        }
      ]
    }
  ],
  "resources": [
    {
      "id": "flow:Vectorstore_search",
      "data": {
        "name": "Vectorstore search",
        "description": "",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "SleepForDebug",
            "type": "label",
            "label": "StartActivity to Sleep"
          },
          {
            "id": 2,
            "from": "SleepForDebug",
            "to": "VectorSearch",
            "type": "label",
            "label": "Sleep to VectorSearch"
          },
          {
            "id": 3,
            "from": "VectorSearch",
            "to": "LogMessage",
            "type": "label",
            "label": "VectorSearch to LogMessage"
          },
          {
            "id": 4,
            "from": "LogMessage",
            "to": "Return",
            "type": "label",
            "label": "LogMessage to Return"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "NoOp Activity",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "SleepForDebug",
            "name": "SleepForDebug",
            "description": "Simple sleep Activity",
            "activity": {
              "ref": "#sleep",
              "input": {
                "IntervalTypeSetting": "Second",
                "IntervalSetting": 1
              }
            }
          },
          {
            "id": "VectorSearch",
            "name": "VectorSearch",
            "description": "This activity searches a vector store for relevant information based on a query",
            "settings": {
              "retryOnError": {
                "count": 0,
                "interval": 0
              }
            },
            "activity": {
              "ref": "#vectorSearch",
              "settings": {
                "endPointURL": "=$property[\"OPENAI_API_ENDPOINT_URL\"]",
                "apiKey": "=$property[\"OPEN_AI_API_KEY\"]"
              },
              "input": {
                "vectorStoreID": "=$property[\"VECTORSTORE_ID\"]",
                "searchString": "tell me something about bwce",
                "maxNumberOfResults": 3,
                "rewriteQuery": false,
                "ranker": ""
              }
            }
          },
          {
            "id": "LogMessage",
            "name": "LogMessage",
            "description": "Simple Log Message Activity",
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": false,
                "message": "=coerce.toString($activity[VectorSearch].searchResultRows)",
                "logLevel": ""
              }
            }
          },
          {
            "id": "Return",
            "name": "Return",
            "description": "Simple Return Activity",
            "activity": {
              "ref": "#actreturn"
            }
          }
        ],
        "fe_metadata": "eyJTdGFydEFjdGl2aXR5Ijp7IngiOjAsInkiOjcyfSwiU2xlZXBGb3JEZWJ1ZyI6eyJ4IjoxMTcsInkiOjYzfSwiVmVjdG9yU2VhcmNoIjp7IngiOjM0MiwieSI6NjR9LCJMb2dNZXNzYWdlIjp7IngiOjYyMywieSI6NjN9LCJSZXR1cm4iOnsieCI6ODk4LCJ5Ijo2N319",
        "metadata": {
          "input": [],
          "output": [],
          "fe_metadata": {}
        }
      }
    }
  ],
  "properties": [
    {
      "name": "VECTORSTORE_ID",
      "type": "string",
      "value": "REPLACE ME"
    },
    {
      "name": "OPENAI_API_ENDPOINT_URL",
      "type": "string",
      "value": "https://api.openai.com/v1"
    },
    {
      "name": "OPEN_AI_API_KEY",
      "type": "string",
      "value": "REPLACE ME"
    }
  ],
  "connections": {},
  "contrib": "",
  "metadata": {
    "endpoints": [],
    "flogoVersion": "2.26.0"
  }
}