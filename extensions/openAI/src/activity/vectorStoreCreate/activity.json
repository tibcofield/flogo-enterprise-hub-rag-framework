{
  "name": "openai-vector-store-create",
  "version": "1.0.0",
  "type": "flogo:activity",
  "title": "Create Vector Store",
  "author": "TIBCO Software",
  "ref": "github.com/TIBCOSoftware/flogo-enterprise-hub/extensions/openAI/activity/vectorStoreCreate",
  "display": {
    "category": "openAI",
    "visible": true,
    "description": "This activity creates a new vector store in OpenAI",
    "smallIcon": "icons/openAPISmall.png",
    "largeIcon": "icons/openAPILarge.png"
  },
  "feature": {
    "retry": {
      "enabled": true
    }
  },
  "settings": [
    {
      "name": "endPointURL",
      "type": "string",
      "required": true,
      "display": {
        "name": "API Endpoint URL",
        "description": "Endpoint URL for the OpenAI API, for example https://api.openai.com/v1",
        "appPropertySupport": true
      }
    },
    {
      "name": "apiKey",
      "type": "string",
      "required": true,
      "display": {
        "name": "OpenAI API Key",
        "description": "OpenAI key that is required to authenticate with the OpenAI API",
        "appPropertySupport": true
      }
    }
  ],
  "inputs": [
    {
      "name": "name",
      "type": "string",
      "required": false
    },
    {
      "name": "description",
      "type": "string",
      "required": false
    },
    {
      "name": "fileIds",
      "type": "array",
      "required": false,
      "enablecoercing": true
    },
    {
      "name": "metadata",
      "type": "array",
      "required": false,
      "enablecoercing": true
    },
    {
      "name": "expiresAfterDays",
      "type": "integer",
      "required": false
    },
    {
      "name": "maxChunkSizeTokens",
      "type": "integer",
      "required": false
    },
    {
      "name": "chunkOverlapTokens",
      "type": "integer",
      "required": false
    },
    {
      "name": "timeoutSeconds",
      "type": "integer",
      "required": false,
      "value": 60
    }
  ],
  "outputs": [
    {
      "name": "id",
      "type": "string"
    },
    {
      "name": "object",
      "type": "string"
    },
    {
      "name": "name",
      "type": "string"
    },
    {
      "name": "status",
      "type": "string"
    },
    {
      "name": "createdAt",
      "type": "integer"
    },
    {
      "name": "lastActiveAt",
      "type": "integer"
    },
    {
      "name": "expiresAt",
      "type": "integer"
    },
    {
      "name": "usageBytes",
      "type": "integer"
    },
    {
      "name": "fileCountsTotal",
      "type": "integer"
    },
    {
      "name": "fileCountsCompleted",
      "type": "integer"
    },
    {
      "name": "fileCountsFailed",
      "type": "integer"
    },
    {
      "name": "fileCountsInProgress",
      "type": "integer"
    },
    {
      "name": "fileCountsCancelled",
      "type": "integer"
    },
    {
      "name": "metadata",
      "type": "object",
      "enablecoercing": true
    }
  ]
}
