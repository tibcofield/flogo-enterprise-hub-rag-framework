# OpenAI Upload File Activity - Environment Variables for Unit Testing
# 
# Instructions:
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your actual values in the .env file
# 3. The .env file is gitignored, so your secrets won't be committed
# 4. Only commit changes to this .env.example template file

# OpenAI API Configuration
# Your OpenAI API key (required for API authentication)
OPEN_AI_API_KEY=your_openai_api_key_here

# OpenAI API Endpoint URL (optional - defaults to OpenAI's standard endpoint)
# Use this if you're using Azure OpenAI or a custom endpoint
OPENAI_API_ENDPOINT_URL=https://api.openai.com/v1

# Vector Store Configuration
# The ID of the OpenAI vector store to upload files to
VECTOR_STORE_ID=your_vector_store_id_here

# Test Control
# Set to "1" to enable integration tests, leave empty or set to "0" to skip
# Integration tests require valid API credentials and will make actual API calls
RUN_INTEGRATION=0

# Optional: Additional test configuration
# These are set in the test code but you can override them here if needed
# TEST_TIMEOUT_SECONDS=300
# TEST_CHUNK_OVERLAP_TOKENS=400
# TEST_MAX_CHUNK_SIZE_TOKENS=800
# TEST_PURPOSE=assistants