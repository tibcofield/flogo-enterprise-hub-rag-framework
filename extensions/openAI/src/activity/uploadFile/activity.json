{
  "name": "openai-upload-file",
  "version": "1.0.1",
  "type": "flogo:activity",
  "title": "Upload File",
  "author": "TIBCO Software",
  "ref": "github.com/TIBCOSoftware/flogo-enterprise-hub/extensions/openAI/activity/uploadFile",
  "display": {
    "category": "openAI",
    "visible": true,
    "description": "This activity uploads files to OpenAI file store",
    "smallIcon": "icons/openAPISmall.png",
    "largeIcon": "icons/openAPILarge.png"
  },
  "feature": {
    "retry": {
      "enabled": true
    }
  },
  "settings": [
    {
      "name": "endPointURL",
      "type": "string",
      "required": true,
      "display": {
        "name": "API Endopoint URL",
        "description": "Endpoint URL for the OpenAI API, for example https://api.openai.com/v1",
        "appPropertySupport": true
      }
    },
    {
      "name": "apiKey",
      "type": "string",
      "required": true,
      "display": {
        "name": "OpenAI API Key",
        "description": "OpenAI key that is required to authenticate with the OpenAI API",
        "appPropertySupport": true
      }
    },
    {
      "name": "purpose",
      "type": "string",
      "required": true,
      "value": "assistants",
      "display": {
        "name": "Output Format",
        "description": "The intended purpose of the uploaded file"
      },
      "allowed": [
        "assistants",
        "batch",
        "fine-tune",
        "vision",
        "user_data",
        "evals"
      ]
    },
    {
      "name": "vectorStoreID",
      "type": "string",
      "required": false,
      "value": "",
      "display": {
        "name": "Vector Store ID",
        "description": "If populated will add the file to the vector store",
        "appPropertySupport": true
      }
    },
    {
      "name": "maxChunkSizeTokens",
      "type": "integer",
      "required": false,
      "value": 800,
      "display": {
        "name": "Maximum Chunk Size Tokens",
        "description": "The maximum number of tokens in each chunk. The default value is 800. The minimum value is 100 and the maximum value is 4096.",
        "appPropertySupport": true
      }
    },
    {
      "name": "chunkOverlapTokens",
      "type": "integer",
      "required": false,
      "value": 400,
      "display": {
        "name": "Chunk Overlap Tokens",
        "description": "The number of tokens that overlap between chunks. The default value is 400",
        "appPropertySupport": true
      }
    }
  ],
  "inputs": [
   {
      "name": "filename",
      "type": "string",
      "required": true
    },
    {
      "name": "fileAttributes",
      "type": "object",
      "required": false             
    }
  ],  
  "outputs": [
    {
      "name": "metaData",
      "type": "string"
    }
  ]
}