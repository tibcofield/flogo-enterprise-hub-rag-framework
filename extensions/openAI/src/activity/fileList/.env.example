# OpenAI API Configuration for Integration Tests
# Copy this file to .env and fill in your actual values

# OpenAI API Key (required)
# Get from: https://platform.openai.com/api-keys
OPEN_AI_API_KEY=sk-your-api-key-here

# OpenAI API Endpoint URL (required)
# Use https://api.openai.com/v1 for standard OpenAI API
OPENAI_API_ENDPOINT_URL=https://api.openai.com/v1

# Vector Store ID for integration tests (required for tests)
# Create a vector store via OpenAI API or dashboard and use its ID here
VECTOR_STORE_ID=vs_your_vector_store_id_here

# Optional: Set to 1 to run integration tests
# RUN_INTEGRATION=1
