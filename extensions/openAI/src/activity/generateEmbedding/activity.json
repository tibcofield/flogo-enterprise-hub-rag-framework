{
  "name": "openai-generateEmbeding",
  "version": "1.0.1",
  "type": "flogo:activity",
  "title": "Generate Embedding",
  "author": "Mark Bloomfield",
  "ref": "github.com/TIBCOSoftware/flogo-enterprise-hub/extensions/openAI/activity/generateEmbedding",
  "display": {
    "category": "openAI",
    "visible": true,
    "description": "This activity generates embedings using the embedding API",
    "smallIcon": "icons/openAPISmall.png",
    "largeIcon": "icons/openAPILarge.png"
  },
  "feature": {
    "retry": {
      "enabled": true
    }
  },
  "settings": [
    {
      "name": "endPointURL",
      "type": "string",
      "required": true,
      "display": {
        "name": "API Endopoint URL",
        "description": "Endpoint URL for the OpenAI API, for example https://api.openai.com/v1",
        "appPropertySupport": true
      }
    },
    {
      "name": "apiKey",
      "type": "string",
      "required": true,
      "display": {
        "name": "OpenAI API Key",
        "description": "OpenAI key that is required to authenticate with the OpenAI API",
        "appPropertySupport": true
      }
    },
    {
      "name": "maxRetries",
      "type": "integer",
      "required": true,
      "value": 2,
      "display": {
        "name": "Max Retries",
        "description": "The maximum amount of retries allowed before failing",
        "appPropertySupport": true
      }
    },
     {
      "name": "embeddingModel",
      "type": "string",
      "required": false,
      "value": "text-embedding-3-small",
      "display": {
        "name": "Embedding Model",
        "description": "The Model to use for the embeding",
        "appPropertySupport": true
      }
    },
    {
      "name": "ebeddingFormat",
      "type": "string",
      "required": true,
      "value": "float",
      "display": {
        "name": "Embedding Format",
        "description": "The Format the embedding is returned in"
      },
      "allowed": [
        "float",
        "base64"
      ]
    },
    {
      "name": "dimensions",
      "type": "integer",
      "required": true,
      "value": 1536,
      "display": {
        "name": "Embedding Dimensions",
        "description": "Min 256, Max 1536 for text-embedding-3-small or 3072 for text-embedding-3-large",
        "appPropertySupport": true
      }
    },
    {
      "name": "safetyIdentifier",
      "type": "string",
      "required": true,
      "display": {
        "name": "Safety Identifier",
        "description": "Safety identifier Session ID or UserID",
        "appPropertySupport": true,
        "mappable": true
      }
    }
  ],
  "inputs":
  [
  {
      "name": "prompt",
      "type": "string",
      "required": true
    }
  ],
  "outputs": [
    {
      "name": "embedding",
      "type": "string"
    },
    {
      "name": "embeddingMetadata",
      "type": "string"
    }
  ]
}