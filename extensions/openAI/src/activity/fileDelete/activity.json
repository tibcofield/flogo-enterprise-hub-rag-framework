{
  "name": "openai-file-delete",
  "version": "1.0.0",
  "type": "flogo:activity",
  "title": "File Delete",
  "author": "TIBCO Software",
  "ref": "github.com/TIBCOSoftware/flogo-enterprise-hub/extensions/openAI/activity/fileDelete",
  "display": {
    "category": "openAI",
    "visible": true,
    "description": "This activity deletes a file from OpenAI's file store",
    "smallIcon": "icons/openAPISmall.png",
    "largeIcon": "icons/openAPILarge.png"
  },
  "feature": {
    "retry": {
      "enabled": true
    }
  },
  "settings": [
    {
      "name": "endPointURL",
      "type": "string",
      "required": true,
      "display": {
        "name": "API Endpoint URL",
        "description": "Endpoint URL for the OpenAI API, for example https://api.openai.com/v1",
        "appPropertySupport": true
      }
    },
    {
      "name": "apiKey",
      "type": "string",
      "required": true,
      "display": {
        "name": "OpenAI API Key",
        "description": "OpenAI key that is required to authenticate with the OpenAI API",
        "appPropertySupport": true
      }
    }
  ],
  "inputs": [
    {
      "name": "fileId",
      "type": "string",
      "required": true
    },
    {
      "name": "timeoutSeconds",
      "type": "integer",
      "required": false
    }
  ],
  "outputs": [
    {
      "name": "id",
      "type": "string"
    },
    {
      "name": "object",
      "type": "string"
    },
    {
      "name": "deleted",
      "type": "boolean"
    }
  ]
}
