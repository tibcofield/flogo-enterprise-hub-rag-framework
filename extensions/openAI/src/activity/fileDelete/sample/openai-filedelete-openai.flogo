{
  "imports": [
    "github.com/project-flogo/flow",
    "github.com/project-flogo/contrib/activity/noop",
    "github.com/tibco/flogo-general/src/app/General/activity/sleep",
    "github.com/TIBCOSoftware/flogo-enterprise-hub/extensions/openAI/activity/fileDelete",
    "github.com/tibco/flogo-general/src/app/General/activity/log",
    "github.com/project-flogo/contrib/activity/actreturn",
    "github.com/tibco/flogo-general/src/app/General/trigger/startuphook",
    "github.com/project-flogo/contrib/function/coerce",
    "github.com/project-flogo/contrib/function/string"
  ],
  "name": "openaiVectorStore-openAI",
  "description": "",
  "version": "1.0.0",
  "type": "flogo:app",
  "appModel": "1.1.1",
  "tags": [],
  "triggers": [
    {
      "ref": "#startuphook",
      "name": "tibco-appstartup",
      "description": "This trigger allows you to execute flows before other triggers in the application are started. This is useful in initializing application specific tasks.",
      "settings": {},
      "id": "AppStartupTrigger",
      "handlers": [
        {
          "description": "",
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:File_Delete"
            }
          },
          "name": "File_Delete"
        }
      ]
    }
  ],
  "resources": [
    {
      "id": "flow:File_Delete",
      "data": {
        "name": "File Delete",
        "description": "",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "SleepForDebug",
            "type": "label",
            "label": "StartActivity to Sleep"
          },
          {
            "id": 2,
            "from": "SleepForDebug",
            "to": "DeleteFile",
            "type": "label",
            "label": "SleepForDebug to DeleteFile"
          },
          {
            "id": 3,
            "from": "DeleteFile",
            "to": "LogMessage",
            "type": "label",
            "label": "DeleteFile to LogMessage"
          },
          {
            "id": 4,
            "from": "LogMessage",
            "to": "Return",
            "type": "label",
            "label": "LogMessage to Return"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "NoOp Activity",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "SleepForDebug",
            "name": "SleepForDebug",
            "description": "Simple sleep Activity",
            "activity": {
              "ref": "#sleep",
              "input": {
                "IntervalTypeSetting": "Millisecond",
                "IntervalSetting": 0
              }
            }
          },
          {
            "id": "DeleteFile",
            "name": "DeleteFile",
            "description": "This activity deletes a file from OpenAI's file store",
            "settings": {
              "retryOnError": {
                "count": 0,
                "interval": 0
              }
            },
            "activity": {
              "ref": "#fileDelete",
              "settings": {
                "endPointURL": "=$property[\"OPENAI_API_ENDPOINT_URL\"]",
                "apiKey": "=$property[\"OPENAI_API_KEY\"]"
              },
              "input": {
                "fileId": "file-GUwKmEnMeAiUy1y1wyWGQu"
              },
              "output": {
                "deleted": false
              }
            }
          },
          {
            "id": "LogMessage",
            "name": "LogMessage",
            "description": "Simple Log Message Activity",
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": false,
                "message": "=string.concat(\"File delete: \",$activity[DeleteFile].id, \" object: \" ,$activity[DeleteFile].object, \" deleted?: \",  coerce.toString($activity[DeleteFile].deleted))",
                "logLevel": "INFO"
              }
            }
          },
          {
            "id": "Return",
            "name": "Return",
            "description": "Simple Return Activity",
            "activity": {
              "ref": "#actreturn"
            }
          }
        ],
        "fe_metadata": "eyJTdGFydEFjdGl2aXR5Ijp7IngiOjEwMCwieSI6MTAwfSwiU2xlZXBGb3JEZWJ1ZyI6eyJ4IjoyMTQsInkiOjk3fSwiRGVsZXRlRmlsZSI6eyJ4Ijo0MjcsInkiOjk0fSwiTG9nTWVzc2FnZSI6eyJ4Ijo2NjgsInkiOjkyfSwiUmV0dXJuIjp7IngiOjg3MywieSI6OTZ9fQ==",
        "metadata": {
          "input": [],
          "output": [],
          "fe_metadata": {}
        }
      }
    }
  ],
  "properties": [
    {
      "name": "VECTORSTORE_ID",
      "type": "string",
      "value": "REPLACE ME"
    },
    {
      "name": "OPENAI_API_ENDPOINT_URL",
      "type": "string",
      "value": "https://api.openai.com/v1"
    },
    {
      "name": "OPENAI_API_KEY",
      "type": "string",
      "value": "REPLACE ME"
    }
  ],
  "connections": {},
  "contrib": "",
  "metadata": {
    "endpoints": [],
    "flogoVersion": "2.26.0"
  }
}