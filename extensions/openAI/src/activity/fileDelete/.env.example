# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_ENDPOINT_URL=https://api.openai.com/v1

# Set to 1 to run integration tests against the real OpenAI API
#RUN_INTEGRATION=1

# Required when RUN_INTEGRATION=1: id of the file to delete
#TEST_FILE_ID=file-abc123

# Optional: Test Configuration
#TEST_TIMEOUT_SECONDS=30
