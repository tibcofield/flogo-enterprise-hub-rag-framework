{
  "imports": [
    "github.com/project-flogo/flow",
    "github.com/project-flogo/contrib/activity/noop",
    "github.com/tibco/flogo-general/src/app/General/activity/sleep",
    "github.com/TIBCOSoftware/flogo-enterprise-hub/extensions/openAI/activity/listVectorStoreFiles",
    "github.com/tibco/flogo-general/src/app/General/activity/mapper",
    "github.com/tibco/flogo-general/src/app/General/activity/log",
    "github.com/project-flogo/contrib/activity/actreturn",
    "github.com/tibco/flogo-general/src/app/General/trigger/startuphook",
    "github.com/project-flogo/contrib/function/array"
  ],
  "name": "openaiVectorStore-openAI",
  "description": "",
  "version": "1.0.0",
  "type": "flogo:app",
  "appModel": "1.1.1",
  "tags": [],
  "triggers": [
    {
      "ref": "#startuphook",
      "name": "tibco-appstartup",
      "description": "This trigger allows you to execute flows before other triggers in the application are started. This is useful in initializing application specific tasks.",
      "settings": {},
      "id": "AppStartupTrigger",
      "handlers": [
        {
          "description": "",
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:List_files_in_vectorstore"
            }
          },
          "name": "List_files_in_vectorstore"
        }
      ]
    }
  ],
  "resources": [
    {
      "id": "flow:List_files_in_vectorstore",
      "data": {
        "name": "List files in vectorstore",
        "description": "",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "SleepToStartDebug",
            "type": "label",
            "label": "StartActivity to Sleep"
          },
          {
            "id": 2,
            "from": "SleepToStartDebug",
            "to": "ListVectorStoreFiles",
            "type": "label",
            "label": "SleepToStartDebug to ListVectorStoreFiles"
          },
          {
            "id": 3,
            "from": "ListVectorStoreFiles",
            "to": "Mapper",
            "type": "label",
            "label": "ListVectorStoreFiles to Mapper"
          },
          {
            "id": 4,
            "from": "Mapper",
            "to": "LogOutput",
            "type": "label",
            "label": "Mapper to LogOutput"
          },
          {
            "id": 5,
            "from": "LogOutput",
            "to": "Return",
            "type": "label",
            "label": "LogOutput to Return"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "NoOp Activity",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "SleepToStartDebug",
            "name": "SleepToStartDebug",
            "description": "Simple sleep Activity",
            "activity": {
              "ref": "#sleep",
              "input": {
                "IntervalTypeSetting": "Second",
                "IntervalSetting": 10
              }
            }
          },
          {
            "id": "ListVectorStoreFiles",
            "name": "ListVectorStoreFiles",
            "description": "This activity lists files in an OpenAI vector store with support for filtering and pagination",
            "settings": {
              "retryOnError": {
                "count": 0,
                "interval": 0
              }
            },
            "activity": {
              "ref": "#listVectorStoreFiles",
              "settings": {
                "endPointURL": "=$property[\"OPENAI_API_ENDPOINT_URL\"]",
                "apiKey": "=$property[\"OPEN_AI_API_KEY\"]"
              },
              "input": {
                "vectorStoreID": "=$property[\"VECTORSTORE_ID\"]",
                "filter": "",
                "order": "",
                "after": "",
                "before": ""
              }
            }
          },
          {
            "id": "Mapper",
            "name": "Mapper",
            "description": "Mapper Activity",
            "activity": {
              "ref": "#mapper",
              "input": {
                "input": {
                  "mapping": {
                    "files": {
                      "@foreach($activity[ListVectorStoreFiles].files,files)": {
                        "=": "$loop"
                      }
                    }
                  }
                }
              },
              "schemas": {
                "input": {
                  "input": {
                    "type": "json",
                    "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\r\n  \"title\": \"OpenAI Vector Store Files Response\",\r\n  \"description\": \"Schema for OpenAI Vector Store list files API response\",\r\n  \"type\": \"object\",\r\n  \"required\": [\"files\"],\r\n  \"properties\": {\r\n    \"files\": {\r\n      \"type\": \"array\",\r\n      \"description\": \"Array of vector store file objects\",\r\n      \"items\": {\r\n        \"type\": \"object\",\r\n        \"required\": [\r\n          \"id\",\r\n          \"created_at\",\r\n          \"last_error\",\r\n          \"object\",\r\n          \"status\",\r\n          \"usage_bytes\",\r\n          \"vector_store_id\",\r\n          \"attributes\",\r\n          \"chunking_strategy\"\r\n        ],\r\n        \"properties\": {\r\n          \"id\": {\r\n            \"type\": \"string\",\r\n            \"description\": \"Unique identifier for the file\",\r\n            \"pattern\": \"^file-[a-zA-Z0-9]+$\"\r\n          },\r\n          \"created_at\": {\r\n            \"type\": \"integer\",\r\n            \"description\": \"Unix timestamp when the file was created\",\r\n            \"minimum\": 0\r\n          },\r\n          \"last_error\": {\r\n            \"type\": \"object\",\r\n            \"description\": \"Information about the last error encountered\",\r\n            \"required\": [\"code\", \"message\"],\r\n            \"properties\": {\r\n              \"code\": {\r\n                \"type\": \"string\",\r\n                \"description\": \"Error code\"\r\n              },\r\n              \"message\": {\r\n                \"type\": \"string\",\r\n                \"description\": \"Error message\"\r\n              }\r\n            }\r\n          },\r\n          \"object\": {\r\n            \"type\": \"string\",\r\n            \"description\": \"Object type identifier\",\r\n            \"enum\": [\"vector_store.file\"]\r\n          },\r\n          \"status\": {\r\n            \"type\": \"string\",\r\n            \"description\": \"Processing status of the file\",\r\n            \"enum\": [\"completed\", \"processing\", \"failed\", \"cancelled\"]\r\n          },\r\n          \"usage_bytes\": {\r\n            \"type\": \"integer\",\r\n            \"description\": \"Number of bytes used by the file\",\r\n            \"minimum\": 0\r\n          },\r\n          \"vector_store_id\": {\r\n            \"type\": \"string\",\r\n            \"description\": \"ID of the vector store containing this file\",\r\n            \"pattern\": \"^vs_[a-zA-Z0-9]+$\"\r\n          },\r\n          \"attributes\": {\r\n            \"type\": \"object\",\r\n            \"description\": \"Custom attributes associated with the file\",\r\n            \"additionalProperties\": false,\r\n            \"properties\": {\r\n              \"DocGroup\": {\r\n                \"$ref\": \"#/definitions/AttributeValue\"\r\n              },\r\n              \"DocType\": {\r\n                \"$ref\": \"#/definitions/AttributeValue\"\r\n              },\r\n              \"Download URL\": {\r\n                \"$ref\": \"#/definitions/AttributeValue\"\r\n              }\r\n            }\r\n          },\r\n          \"chunking_strategy\": {\r\n            \"type\": \"object\",\r\n            \"description\": \"Strategy used for chunking the file\",\r\n            \"required\": [\"type\"],\r\n            \"properties\": {\r\n              \"type\": {\r\n                \"type\": \"string\",\r\n                \"description\": \"Type of chunking strategy\",\r\n                \"enum\": [\"static\", \"auto\"]\r\n              },\r\n              \"static\": {\r\n                \"type\": \"object\",\r\n                \"description\": \"Static chunking configuration\",\r\n                \"required\": [\"chunk_overlap_tokens\", \"max_chunk_size_tokens\"],\r\n                \"properties\": {\r\n                  \"chunk_overlap_tokens\": {\r\n                    \"type\": \"integer\",\r\n                    \"description\": \"Number of tokens to overlap between chunks\",\r\n                    \"minimum\": 0\r\n                  },\r\n                  \"max_chunk_size_tokens\": {\r\n                    \"type\": \"integer\",\r\n                    \"description\": \"Maximum size of each chunk in tokens\",\r\n                    \"minimum\": 0\r\n                  }\r\n                }\r\n              }\r\n            }\r\n          }\r\n        }\r\n      }\r\n    }\r\n  },\r\n  \"definitions\": {\r\n    \"AttributeValue\": {\r\n      \"type\": \"object\",\r\n      \"description\": \"Custom attribute value with typed fields\",\r\n      \"required\": [\"OfString\", \"OfFloat\", \"OfBool\"],\r\n      \"properties\": {\r\n        \"OfString\": {\r\n          \"type\": \"string\",\r\n          \"description\": \"String value of the attribute\"\r\n        },\r\n        \"OfFloat\": {\r\n          \"type\": \"number\",\r\n          \"description\": \"Float value of the attribute\"\r\n        },\r\n        \"OfBool\": {\r\n          \"type\": \"boolean\",\r\n          \"description\": \"Boolean value of the attribute\"\r\n        }\r\n      }\r\n    }\r\n  }\r\n}",
                    "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\r\n  \"title\": \"OpenAI Vector Store Files Response\",\r\n  \"description\": \"Schema for OpenAI Vector Store list files API response\",\r\n  \"type\": \"object\",\r\n  \"required\": [\"files\"],\r\n  \"properties\": {\r\n    \"files\": {\r\n      \"type\": \"array\",\r\n      \"description\": \"Array of vector store file objects\",\r\n      \"items\": {\r\n        \"type\": \"object\",\r\n        \"required\": [\r\n          \"id\",\r\n          \"created_at\",\r\n          \"last_error\",\r\n          \"object\",\r\n          \"status\",\r\n          \"usage_bytes\",\r\n          \"vector_store_id\",\r\n          \"attributes\",\r\n          \"chunking_strategy\"\r\n        ],\r\n        \"properties\": {\r\n          \"id\": {\r\n            \"type\": \"string\",\r\n            \"description\": \"Unique identifier for the file\",\r\n            \"pattern\": \"^file-[a-zA-Z0-9]+$\"\r\n          },\r\n          \"created_at\": {\r\n            \"type\": \"integer\",\r\n            \"description\": \"Unix timestamp when the file was created\",\r\n            \"minimum\": 0\r\n          },\r\n          \"last_error\": {\r\n            \"type\": \"object\",\r\n            \"description\": \"Information about the last error encountered\",\r\n            \"required\": [\"code\", \"message\"],\r\n            \"properties\": {\r\n              \"code\": {\r\n                \"type\": \"string\",\r\n                \"description\": \"Error code\"\r\n              },\r\n              \"message\": {\r\n                \"type\": \"string\",\r\n                \"description\": \"Error message\"\r\n              }\r\n            }\r\n          },\r\n          \"object\": {\r\n            \"type\": \"string\",\r\n            \"description\": \"Object type identifier\",\r\n            \"enum\": [\"vector_store.file\"]\r\n          },\r\n          \"status\": {\r\n            \"type\": \"string\",\r\n            \"description\": \"Processing status of the file\",\r\n            \"enum\": [\"completed\", \"processing\", \"failed\", \"cancelled\"]\r\n          },\r\n          \"usage_bytes\": {\r\n            \"type\": \"integer\",\r\n            \"description\": \"Number of bytes used by the file\",\r\n            \"minimum\": 0\r\n          },\r\n          \"vector_store_id\": {\r\n            \"type\": \"string\",\r\n            \"description\": \"ID of the vector store containing this file\",\r\n            \"pattern\": \"^vs_[a-zA-Z0-9]+$\"\r\n          },\r\n          \"attributes\": {\r\n            \"type\": \"object\",\r\n            \"description\": \"Custom attributes associated with the file\",\r\n            \"additionalProperties\": false,\r\n            \"properties\": {\r\n              \"DocGroup\": {\r\n                \"$ref\": \"#/definitions/AttributeValue\"\r\n              },\r\n              \"DocType\": {\r\n                \"$ref\": \"#/definitions/AttributeValue\"\r\n              },\r\n              \"Download URL\": {\r\n                \"$ref\": \"#/definitions/AttributeValue\"\r\n              }\r\n            }\r\n          },\r\n          \"chunking_strategy\": {\r\n            \"type\": \"object\",\r\n            \"description\": \"Strategy used for chunking the file\",\r\n            \"required\": [\"type\"],\r\n            \"properties\": {\r\n              \"type\": {\r\n                \"type\": \"string\",\r\n                \"description\": \"Type of chunking strategy\",\r\n                \"enum\": [\"static\", \"auto\"]\r\n              },\r\n              \"static\": {\r\n                \"type\": \"object\",\r\n                \"description\": \"Static chunking configuration\",\r\n                \"required\": [\"chunk_overlap_tokens\", \"max_chunk_size_tokens\"],\r\n                \"properties\": {\r\n                  \"chunk_overlap_tokens\": {\r\n                    \"type\": \"integer\",\r\n                    \"description\": \"Number of tokens to overlap between chunks\",\r\n                    \"minimum\": 0\r\n                  },\r\n                  \"max_chunk_size_tokens\": {\r\n                    \"type\": \"integer\",\r\n                    \"description\": \"Maximum size of each chunk in tokens\",\r\n                    \"minimum\": 0\r\n                  }\r\n                }\r\n              }\r\n            }\r\n          }\r\n        }\r\n      }\r\n    }\r\n  },\r\n  \"definitions\": {\r\n    \"AttributeValue\": {\r\n      \"type\": \"object\",\r\n      \"description\": \"Custom attribute value with typed fields\",\r\n      \"required\": [\"OfString\", \"OfFloat\", \"OfBool\"],\r\n      \"properties\": {\r\n        \"OfString\": {\r\n          \"type\": \"string\",\r\n          \"description\": \"String value of the attribute\"\r\n        },\r\n        \"OfFloat\": {\r\n          \"type\": \"number\",\r\n          \"description\": \"Float value of the attribute\"\r\n        },\r\n        \"OfBool\": {\r\n          \"type\": \"boolean\",\r\n          \"description\": \"Boolean value of the attribute\"\r\n        }\r\n      }\r\n    }\r\n  }\r\n}"
                  }
                },
                "output": {
                  "output": {
                    "type": "json",
                    "value": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"title\": \"OpenAI Vector Store Files Response\",\n  \"description\": \"Schema for OpenAI Vector Store list files API response\",\n  \"type\": \"object\",\n  \"required\": [\n    \"files\"\n  ],\n  \"properties\": {\n    \"files\": {\n      \"type\": \"array\",\n      \"description\": \"Array of vector store file objects\",\n      \"items\": {\n        \"type\": \"object\",\n        \"required\": [\n          \"id\",\n          \"created_at\",\n          \"last_error\",\n          \"object\",\n          \"status\",\n          \"usage_bytes\",\n          \"vector_store_id\",\n          \"attributes\",\n          \"chunking_strategy\"\n        ],\n        \"properties\": {\n          \"id\": {\n            \"type\": \"string\",\n            \"description\": \"Unique identifier for the file\",\n            \"pattern\": \"^file-[a-zA-Z0-9]+$\"\n          },\n          \"created_at\": {\n            \"type\": \"integer\",\n            \"description\": \"Unix timestamp when the file was created\",\n            \"minimum\": 0\n          },\n          \"last_error\": {\n            \"type\": \"object\",\n            \"description\": \"Information about the last error encountered\",\n            \"required\": [\n              \"code\",\n              \"message\"\n            ],\n            \"properties\": {\n              \"code\": {\n                \"type\": \"string\",\n                \"description\": \"Error code\"\n              },\n              \"message\": {\n                \"type\": \"string\",\n                \"description\": \"Error message\"\n              }\n            }\n          },\n          \"object\": {\n            \"type\": \"string\",\n            \"description\": \"Object type identifier\",\n            \"enum\": [\n              \"vector_store.file\"\n            ]\n          },\n          \"status\": {\n            \"type\": \"string\",\n            \"description\": \"Processing status of the file\",\n            \"enum\": [\n              \"completed\",\n              \"processing\",\n              \"failed\",\n              \"cancelled\"\n            ]\n          },\n          \"usage_bytes\": {\n            \"type\": \"integer\",\n            \"description\": \"Number of bytes used by the file\",\n            \"minimum\": 0\n          },\n          \"vector_store_id\": {\n            \"type\": \"string\",\n            \"description\": \"ID of the vector store containing this file\",\n            \"pattern\": \"^vs_[a-zA-Z0-9]+$\"\n          },\n          \"attributes\": {\n            \"type\": \"object\",\n            \"description\": \"Custom attributes associated with the file\",\n            \"additionalProperties\": false,\n            \"properties\": {\n              \"DocGroup\": {\n                \"$ref\": \"#/definitions/AttributeValue\"\n              },\n              \"DocType\": {\n                \"$ref\": \"#/definitions/AttributeValue\"\n              },\n              \"Download URL\": {\n                \"$ref\": \"#/definitions/AttributeValue\"\n              }\n            }\n          },\n          \"chunking_strategy\": {\n            \"type\": \"object\",\n            \"description\": \"Strategy used for chunking the file\",\n            \"required\": [\n              \"type\"\n            ],\n            \"properties\": {\n              \"type\": {\n                \"type\": \"string\",\n                \"description\": \"Type of chunking strategy\",\n                \"enum\": [\n                  \"static\",\n                  \"auto\"\n                ]\n              },\n              \"static\": {\n                \"type\": \"object\",\n                \"description\": \"Static chunking configuration\",\n                \"required\": [\n                  \"chunk_overlap_tokens\",\n                  \"max_chunk_size_tokens\"\n                ],\n                \"properties\": {\n                  \"chunk_overlap_tokens\": {\n                    \"type\": \"integer\",\n                    \"description\": \"Number of tokens to overlap between chunks\",\n                    \"minimum\": 0\n                  },\n                  \"max_chunk_size_tokens\": {\n                    \"type\": \"integer\",\n                    \"description\": \"Maximum size of each chunk in tokens\",\n                    \"minimum\": 0\n                  }\n                }\n              }\n            }\n          }\n        }\n      }\n    }\n  },\n  \"definitions\": {\n    \"AttributeValue\": {\n      \"type\": \"object\",\n      \"description\": \"Custom attribute value with typed fields\",\n      \"required\": [\n        \"OfString\",\n        \"OfFloat\",\n        \"OfBool\"\n      ],\n      \"properties\": {\n        \"OfString\": {\n          \"type\": \"string\",\n          \"description\": \"String value of the attribute\"\n        },\n        \"OfFloat\": {\n          \"type\": \"number\",\n          \"description\": \"Float value of the attribute\"\n        },\n        \"OfBool\": {\n          \"type\": \"boolean\",\n          \"description\": \"Boolean value of the attribute\"\n        }\n      }\n    }\n  }\n}",
                    "fe_metadata": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"title\": \"OpenAI Vector Store Files Response\",\n  \"description\": \"Schema for OpenAI Vector Store list files API response\",\n  \"type\": \"object\",\n  \"required\": [\n    \"files\"\n  ],\n  \"properties\": {\n    \"files\": {\n      \"type\": \"array\",\n      \"description\": \"Array of vector store file objects\",\n      \"items\": {\n        \"type\": \"object\",\n        \"required\": [\n          \"id\",\n          \"created_at\",\n          \"last_error\",\n          \"object\",\n          \"status\",\n          \"usage_bytes\",\n          \"vector_store_id\",\n          \"attributes\",\n          \"chunking_strategy\"\n        ],\n        \"properties\": {\n          \"id\": {\n            \"type\": \"string\",\n            \"description\": \"Unique identifier for the file\",\n            \"pattern\": \"^file-[a-zA-Z0-9]+$\"\n          },\n          \"created_at\": {\n            \"type\": \"integer\",\n            \"description\": \"Unix timestamp when the file was created\",\n            \"minimum\": 0\n          },\n          \"last_error\": {\n            \"type\": \"object\",\n            \"description\": \"Information about the last error encountered\",\n            \"required\": [\n              \"code\",\n              \"message\"\n            ],\n            \"properties\": {\n              \"code\": {\n                \"type\": \"string\",\n                \"description\": \"Error code\"\n              },\n              \"message\": {\n                \"type\": \"string\",\n                \"description\": \"Error message\"\n              }\n            }\n          },\n          \"object\": {\n            \"type\": \"string\",\n            \"description\": \"Object type identifier\",\n            \"enum\": [\n              \"vector_store.file\"\n            ]\n          },\n          \"status\": {\n            \"type\": \"string\",\n            \"description\": \"Processing status of the file\",\n            \"enum\": [\n              \"completed\",\n              \"processing\",\n              \"failed\",\n              \"cancelled\"\n            ]\n          },\n          \"usage_bytes\": {\n            \"type\": \"integer\",\n            \"description\": \"Number of bytes used by the file\",\n            \"minimum\": 0\n          },\n          \"vector_store_id\": {\n            \"type\": \"string\",\n            \"description\": \"ID of the vector store containing this file\",\n            \"pattern\": \"^vs_[a-zA-Z0-9]+$\"\n          },\n          \"attributes\": {\n            \"type\": \"object\",\n            \"description\": \"Custom attributes associated with the file\",\n            \"additionalProperties\": false,\n            \"properties\": {\n              \"DocGroup\": {\n                \"$ref\": \"#/definitions/AttributeValue\"\n              },\n              \"DocType\": {\n                \"$ref\": \"#/definitions/AttributeValue\"\n              },\n              \"Download URL\": {\n                \"$ref\": \"#/definitions/AttributeValue\"\n              }\n            }\n          },\n          \"chunking_strategy\": {\n            \"type\": \"object\",\n            \"description\": \"Strategy used for chunking the file\",\n            \"required\": [\n              \"type\"\n            ],\n            \"properties\": {\n              \"type\": {\n                \"type\": \"string\",\n                \"description\": \"Type of chunking strategy\",\n                \"enum\": [\n                  \"static\",\n                  \"auto\"\n                ]\n              },\n              \"static\": {\n                \"type\": \"object\",\n                \"description\": \"Static chunking configuration\",\n                \"required\": [\n                  \"chunk_overlap_tokens\",\n                  \"max_chunk_size_tokens\"\n                ],\n                \"properties\": {\n                  \"chunk_overlap_tokens\": {\n                    \"type\": \"integer\",\n                    \"description\": \"Number of tokens to overlap between chunks\",\n                    \"minimum\": 0\n                  },\n                  \"max_chunk_size_tokens\": {\n                    \"type\": \"integer\",\n                    \"description\": \"Maximum size of each chunk in tokens\",\n                    \"minimum\": 0\n                  }\n                }\n              }\n            }\n          }\n        }\n      }\n    }\n  },\n  \"definitions\": {\n    \"AttributeValue\": {\n      \"type\": \"object\",\n      \"description\": \"Custom attribute value with typed fields\",\n      \"required\": [\n        \"OfString\",\n        \"OfFloat\",\n        \"OfBool\"\n      ],\n      \"properties\": {\n        \"OfString\": {\n          \"type\": \"string\",\n          \"description\": \"String value of the attribute\"\n        },\n        \"OfFloat\": {\n          \"type\": \"number\",\n          \"description\": \"Float value of the attribute\"\n        },\n        \"OfBool\": {\n          \"type\": \"boolean\",\n          \"description\": \"Boolean value of the attribute\"\n        }\n      }\n    }\n  }\n}"
                  }
                }
              },
              "feSchemaMap": {}
            }
          },
          {
            "id": "LogOutput",
            "name": "LogOutput",
            "description": "Simple Log Message Activity",
            "type": "iterator",
            "settings": {
              "iterate": "=$activity[Mapper].output.files",
              "accumulate": false
            },
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": false,
                "message": "=$activity[Mapper].output.files[($iteration[index])].id",
                "logLevel": ""
              }
            }
          },
          {
            "id": "Return",
            "name": "Return",
            "description": "Simple Return Activity",
            "activity": {
              "ref": "#actreturn"
            }
          }
        ],
        "fe_metadata": "eyJTdGFydEFjdGl2aXR5Ijp7IngiOjUsInkiOjkzfSwiU2xlZXBUb1N0YXJ0RGVidWciOnsieCI6MTA2LCJ5Ijo4N30sIkxpc3RWZWN0b3JTdG9yZUZpbGVzIjp7IngiOjM4OCwieSI6ODV9LCJNYXBwZXIiOnsieCI6NTg5LCJ5Ijo4NX0sIkxvZ091dHB1dCI6eyJ4Ijo4MjIsInkiOjg5fSwiUmV0dXJuIjp7IngiOjEwMzEsInkiOjkzfX0=",
        "metadata": {
