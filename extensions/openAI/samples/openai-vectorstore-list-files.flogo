        }
      }
    }
  ],
  "properties": [
    {
      "name": "VECTORSTORE_ID",
      "type": "string",
      "value": "REPLACE ME"
    },
    {
      "name": "OPENAI_API_ENDPOINT_URL",
      "type": "string",
      "value": "https://api.openai.com/v1"
    },
    {
      "name": "OPEN_AI_API_KEY",
      "type": "string",
      "value": "REPLACE ME"
    }
  ],
  "connections": {},
  "contrib": "",
