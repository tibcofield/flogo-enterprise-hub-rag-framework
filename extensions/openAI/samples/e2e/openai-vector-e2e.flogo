{
  "imports": [
    "github.com/project-flogo/flow",
    "github.com/project-flogo/contrib/activity/noop",
    "github.com/TIBCOSoftware/flogo-enterprise-hub/extensions/openAI/activity/vectorStoreCreate",
    "github.com/tibco/flogo-general/src/app/General/activity/log",
    "github.com/TIBCOSoftware/flogo-enterprise-hub/extensions/openAI/activity/fileUpload",
    "github.com/tibco/flogo-general/src/app/General/activity/sleep",
    "github.com/TIBCOSoftware/flogo-enterprise-hub/extensions/openAI/activity/fileList",
    "github.com/TIBCOSoftware/flogo-enterprise-hub/extensions/openAI/activity/vectorSearch",
    "github.com/TIBCOSoftware/flogo-enterprise-hub/extensions/openAI/activity/fileDelete",
    "github.com/TIBCOSoftware/flogo-enterprise-hub/extensions/openAI/activity/vectorStoreDelete",
    "github.com/project-flogo/contrib/activity/actreturn",
    "github.com/tibco/flogo-general/src/app/General/trigger/startuphook",
    "github.com/project-flogo/contrib/function/string",
    "github.com/project-flogo/contrib/function/coerce"
  ],
  "name": "openai-vector-e2e",
  "description": "",
  "version": "1.0.0",
  "type": "flogo:app",
  "appModel": "1.1.1",
  "tags": [],
  "triggers": [
    {
      "ref": "#startuphook",
      "name": "tibco-appstartup",
      "description": "This trigger allows you to execute flows before other triggers in the application are started. This is useful in initializing application specific tasks.",
      "settings": {},
      "id": "AppStartupTrigger",
      "handlers": [
        {
          "description": "",
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:VectorStore_E2E"
            }
          },
          "name": "VectorStore_E2E"
        }
      ]
    }
  ],
  "resources": [
    {
      "id": "flow:VectorStore_E2E",
      "data": {
        "note": {
          "author": {
            "name": "VS code user",
            "userId": "vscode"
          },
          "content": "Create Vectorstore\nUpload File\nList files in store\nVectorSearch\nDelete vectorstore",
          "createAt": 1777471523969,
          "lastUpdatedAt": 1777471523969,
          "title": "Flow Note"
        },
        "name": "VectorStore E2E",
        "description": "",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "CreateVectorStore",
            "type": "label",
            "label": "StartActivity to CreateVectorStore"
          },
          {
            "id": 2,
            "from": "CreateVectorStore",
            "to": "LogMessage",
            "type": "label",
            "label": "CreateVectorStore to LogMessage"
          },
          {
            "id": 3,
            "from": "LogMessage",
            "to": "UploadFile",
            "type": "label",
            "label": "LogMessage to UploadFile"
          },
          {
            "id": 4,
            "from": "UploadFile",
            "to": "LogMessage2",
            "type": "label",
            "label": "UploadFile to CopyOfLogMessage"
          },
          {
            "id": 5,
            "from": "LogMessage2",
            "to": "Sleep",
            "type": "label",
            "label": "LogMessage2 to Sleep"
          },
          {
            "id": 6,
            "from": "Sleep",
            "to": "FileList",
            "type": "label",
            "label": "Sleep to FileList"
          },
          {
            "id": 7,
            "from": "FileList",
            "to": "LogMessage3",
            "type": "label",
