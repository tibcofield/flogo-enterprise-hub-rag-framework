          },
          {
            "id": 8,
            "from": "LogMessage3",
            "to": "VectorSearch",
            "type": "label",
            "label": "LogMessage3 to VectorSearch"
          },
          {
            "id": 9,
            "from": "VectorSearch",
            "to": "LogMessage4",
            "type": "label",
            "label": "VectorSearch to CopyOfLogMessage3"
          },
          {
            "id": 10,
            "from": "LogMessage4",
            "to": "FileDelete",
            "type": "label",
            "label": "LogMessage4 to FileDelete"
          },
          {
            "id": 11,
            "from": "FileDelete",
            "to": "LogMessage5",
            "type": "label",
            "label": "FileDelete to LogMessage5"
          },
          {
            "id": 12,
            "from": "LogMessage5",
            "to": "DeleteVectorStore",
            "type": "label",
            "label": "LogMessage5 to DeleteVectorStore"
          },
          {
            "id": 13,
            "from": "DeleteVectorStore",
            "to": "Return",
            "type": "label",
            "label": "DeleteVectorStore to Return"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "NoOp Activity",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "CreateVectorStore",
            "name": "CreateVectorStore",
            "description": "This activity creates a new vector store in OpenAI",
            "settings": {
              "retryOnError": {
                "count": 0,
                "interval": 0
              }
            },
            "activity": {
              "ref": "#vectorStoreCreate",
              "settings": {
                "endPointURL": "=$property[\"OPENAI_API_ENDPOINT_URL\"]",
                "apiKey": "=$property[\"OPENAI_API_KEY\"]"
              },
              "input": {
                "name": "VectorStoreTesting",
                "description": "VectorStore test case 1",
                "expiresAfterDays": 1,
                "maxChunkSizeTokens": 400,
                "chunkOverlapTokens": 50,
                "timeoutSeconds": 60,
                "fileIds": {
                  "mapping": [
                    ""
                  ]
                }
              }
            }
          },
          {
            "id": "LogMessage",
            "name": "LogMessage",
            "description": "Simple Log Message Activity",
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": false,
                "message": "=string.concat(\"VectorStore Created: \",$activity[CreateVectorStore].id)",
                "logLevel": "INFO"
              }
            }
          },
          {
            "id": "UploadFile",
            "name": "UploadFile",
            "description": "This activity uploads files to OpenAI file store",
            "settings": {
              "retryOnError": {
                "count": 0,
                "interval": 0
              }
            },
            "activity": {
              "ref": "#fileUpload",
              "settings": {
                "endPointURL": "=$property[\"OPENAI_API_ENDPOINT_URL\"]",
                "apiKey": "=$property[\"OPENAI_API_KEY\"]",
                "purpose": "assistants",
                "maxChunkSizeTokens": 800,
                "chunkOverlapTokens": 400,
                "timeoutSeconds": 300
              },
              "input": {
                "filename": "extensions/openAI/src/activity/fileUpload/testdata/TIB-bwce_6.12_concepts.pdf",
                "vectorStoreID": "=$activity[CreateVectorStore].id"
              }
            }
          },
          {
            "id": "LogMessage2",
            "name": "LogMessage2",
            "description": "Simple Log Message Activity",
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": false,
                "message": "=string.concat(\"File uploaded: \", $activity[UploadFile].id, \" to Vectorstore: \",$activity[CreateVectorStore].id, \" *** Sleeping to allow file to be chuncked and vectorized ***\")",
                "logLevel": "INFO"
              }
            }
          },
          {
            "id": "Sleep",
            "name": "Sleep",
            "description": "Wait for vectors to be created from file upload",
            "activity": {
              "ref": "#sleep",
              "input": {
                "IntervalTypeSetting": "Second",
                "IntervalSetting": 30
              }
            }
          },
          {
            "id": "FileList",
            "name": "FileList",
            "description": "This activity lists files in an OpenAI vector store with support for filtering and pagination",
            "settings": {
              "retryOnError": {
                "count": 0,
                "interval": 0
              }
            },
            "activity": {
              "ref": "#fileList",
              "settings": {
                "endPointURL": "=$property[\"OPENAI_API_ENDPOINT_URL\"]",
                "apiKey": "=$property[\"OPENAI_API_KEY\"]"
              },
              "input": {
                "vectorStoreID": "=$activity[CreateVectorStore].id",
                "limit": 5,
                "filter": "",
                "order": "",
                "after": "",
                "before": ""
              },
              "schemas": {
                "output": {
                  "files": {
                    "type": "json",
                    "value": "{\"$schema\": \"http://json-schema.org/draft-07/schema#\", \"title\": \"OpenAI Vector Store Files\", \"description\": \"Array of vector store file objects returned by the OpenAI list files API\", \"type\": \"array\", \"items\": {\"type\": \"object\", \"required\": [\"id\", \"created_at\", \"last_error\", \"object\", \"status\", \"usage_bytes\", \"vector_store_id\", \"attributes\", \"chunking_strategy\"], \"additionalProperties\": false, \"properties\": {\"id\": {\"type\": \"string\", \"description\": \"Unique identifier for the file\", \"pattern\": \"^file-[a-zA-Z0-9]+$\"}, \"created_at\": {\"type\": \"integer\", \"description\": \"Unix timestamp when the file was created\", \"minimum\": 0}, \"last_error\": {\"type\": \"object\", \"description\": \"Information about the last error encountered (empty strings when no error)\", \"required\": [\"code\", \"message\"], \"additionalProperties\": false, \"properties\": {\"code\": {\"type\": \"string\", \"description\": \"Error code, empty string when no error\"}, \"message\": {\"type\": \"string\", \"description\": \"Error message, empty string when no error\"}}}, \"object\": {\"type\": \"string\", \"description\": \"Object type identifier\", \"enum\": [\"vector_store.file\"]}, \"status\": {\"type\": \"string\", \"description\": \"Processing status of the file\", \"enum\": [\"in_progress\", \"completed\", \"failed\", \"cancelled\"]}, \"usage_bytes\": {\"type\": \"integer\", \"description\": \"Number of bytes used by the file\", \"minimum\": 0}, \"vector_store_id\": {\"type\": \"string\", \"description\": \"ID of the vector store containing this file\", \"pattern\": \"^vs_[a-zA-Z0-9]+$\"}, \"attributes\": {\"type\": \"object\", \"description\": \"Custom attributes associated with the file (free-form key/value pairs)\", \"additionalProperties\": {\"type\": [\"string\", \"number\", \"boolean\", \"null\"]}}, \"chunking_strategy\": {\"type\": \"object\", \"description\": \"Strategy used for chunking the file\", \"required\": [\"type\"], \"additionalProperties\": false, \"properties\": {\"type\": {\"type\": \"string\", \"description\": \"Type of chunking strategy\", \"enum\": [\"static\", \"auto\"]}, \"static\": {\"type\": \"object\", \"description\": \"Static chunking configuration (present when type is static)\", \"required\": [\"chunk_overlap_tokens\", \"max_chunk_size_tokens\"], \"additionalProperties\": false, \"properties\": {\"chunk_overlap_tokens\": {\"type\": \"integer\", \"description\": \"Number of tokens to overlap between chunks\", \"minimum\": 0}, \"max_chunk_size_tokens\": {\"type\": \"integer\", \"description\": \"Maximum size of each chunk in tokens\", \"minimum\": 0}}}}}}}}",
                    "fe_metadata": "{\"$schema\": \"http://json-schema.org/draft-07/schema#\", \"title\": \"OpenAI Vector Store Files\", \"description\": \"Array of vector store file objects returned by the OpenAI list files API\", \"type\": \"array\", \"items\": {\"type\": \"object\", \"required\": [\"id\", \"created_at\", \"last_error\", \"object\", \"status\", \"usage_bytes\", \"vector_store_id\", \"attributes\", \"chunking_strategy\"], \"additionalProperties\": false, \"properties\": {\"id\": {\"type\": \"string\", \"description\": \"Unique identifier for the file\", \"pattern\": \"^file-[a-zA-Z0-9]+$\"}, \"created_at\": {\"type\": \"integer\", \"description\": \"Unix timestamp when the file was created\", \"minimum\": 0}, \"last_error\": {\"type\": \"object\", \"description\": \"Information about the last error encountered (empty strings when no error)\", \"required\": [\"code\", \"message\"], \"additionalProperties\": false, \"properties\": {\"code\": {\"type\": \"string\", \"description\": \"Error code, empty string when no error\"}, \"message\": {\"type\": \"string\", \"description\": \"Error message, empty string when no error\"}}}, \"object\": {\"type\": \"string\", \"description\": \"Object type identifier\", \"enum\": [\"vector_store.file\"]}, \"status\": {\"type\": \"string\", \"description\": \"Processing status of the file\", \"enum\": [\"in_progress\", \"completed\", \"failed\", \"cancelled\"]}, \"usage_bytes\": {\"type\": \"integer\", \"description\": \"Number of bytes used by the file\", \"minimum\": 0}, \"vector_store_id\": {\"type\": \"string\", \"description\": \"ID of the vector store containing this file\", \"pattern\": \"^vs_[a-zA-Z0-9]+$\"}, \"attributes\": {\"type\": \"object\", \"description\": \"Custom attributes associated with the file (free-form key/value pairs)\", \"additionalProperties\": {\"type\": [\"string\", \"number\", \"boolean\", \"null\"]}}, \"chunking_strategy\": {\"type\": \"object\", \"description\": \"Strategy used for chunking the file\", \"required\": [\"type\"], \"additionalProperties\": false, \"properties\": {\"type\": {\"type\": \"string\", \"description\": \"Type of chunking strategy\", \"enum\": [\"static\", \"auto\"]}, \"static\": {\"type\": \"object\", \"description\": \"Static chunking configuration (present when type is static)\", \"required\": [\"chunk_overlap_tokens\", \"max_chunk_size_tokens\"], \"additionalProperties\": false, \"properties\": {\"chunk_overlap_tokens\": {\"type\": \"integer\", \"description\": \"Number of tokens to overlap between chunks\", \"minimum\": 0}, \"max_chunk_size_tokens\": {\"type\": \"integer\", \"description\": \"Maximum size of each chunk in tokens\", \"minimum\": 0}}}}}}}}"
                  }
                }
              },
              "feSchemaMap": {}
            }
          },
          {
            "id": "LogMessage3",
            "name": "LogMessage3",
            "description": "Simple Log Message Activity",
            "type": "iterator",
            "settings": {
              "iterate": "=$activity[FileList].files",
              "accumulate": false
            },
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": false,
                "message": "=string.concat(\"File listed: \" ,coerce.toString($iteration[value]))",
                "logLevel": "INFO"
              }
            }
          },
          {
            "id": "VectorSearch",
            "name": "VectorSearch",
            "description": "This activity searches a vector store for relevant information based on a query",
            "settings": {
              "retryOnError": {
                "count": 0,
                "interval": 0
              }
            },
            "activity": {
              "ref": "#vectorSearch",
              "settings": {
                "endPointURL": "=$property[\"OPENAI_API_ENDPOINT_URL\"]",
                "apiKey": "=$property[\"OPENAI_API_KEY\"]"
              },
              "input": {
                "vectorStoreID": "=$activity[CreateVectorStore].id",
                "searchString": "Tell me something about BWCE",
                "maxNumberOfResults": 5,
                "rewriteQuery": false,
                "ranker": ""
              },
              "schemas": {
                "output": {
                  "searchResultRows": {
                    "type": "json",
                    "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"attributes\":{\"type\":\"object\",\"properties\":{}},\"content\":{\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"text\":{\"type\":\"string\"},\"type\":{\"type\":\"string\"}}}},\"file_id\":{\"type\":\"string\"},\"filename\":{\"type\":\"string\"},\"score\":{\"type\":\"number\"}},\"required\":[\"attributes\",\"content\",\"file_id\",\"filename\",\"score\"]}}",
                    "fe_metadata": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"attributes\":{\"type\":\"object\",\"properties\":{}},\"content\":{\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"text\":{\"type\":\"string\"},\"type\":{\"type\":\"string\"}}}},\"file_id\":{\"type\":\"string\"},\"filename\":{\"type\":\"string\"},\"score\":{\"type\":\"number\"}},\"required\":[\"attributes\",\"content\",\"file_id\",\"filename\",\"score\"]}}"
                  }
                }
              },
              "feSchemaMap": {}
            }
          },
          {
            "id": "LogMessage4",
            "name": "LogMessage4",
            "description": "Simple Log Message Activity",
            "type": "iterator",
            "settings": {
              "iterate": "=$activity[VectorSearch].searchResultRows",
              "accumulate": false
            },
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": false,
                "message": "=string.concat(\"File: \",$iteration[value].filename ,\" Text: \", coerce.toString($iteration[value].content))",
                "logLevel": "INFO"
              }
            }
          },
          {
            "id": "FileDelete",
            "name": "FileDelete",
            "description": "This activity deletes a file from OpenAI's file store",
            "settings": {
              "retryOnError": {
                "count": 0,
                "interval": 0
              }
            },
            "activity": {
              "ref": "#fileDelete",
              "settings": {
                "endPointURL": "=$property[\"OPENAI_API_ENDPOINT_URL\"]",
                "apiKey": "=$property[\"OPENAI_API_KEY\"]"
              },
              "input": {
                "fileId": "=$activity[UploadFile].id"
              }
            }
          },
          {
            "id": "LogMessage5",
            "name": "LogMessage5",
            "description": "Simple Log Message Activity",
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": false,
                "message": "=string.concat(\"File: \",$activity[FileDelete].id ,\" deleted\")",
                "logLevel": "INFO"
              }
            }
          },
          {
            "id": "DeleteVectorStore",
            "name": "DeleteVectorStore",
            "description": "This activity deletes a vector store from OpenAI",
            "settings": {
              "retryOnError": {
                "count": 0,
                "interval": 0
              }
            },
            "activity": {
              "ref": "#vectorStoreDelete",
              "settings": {
                "endPointURL": "=$property[\"OPENAI_API_ENDPOINT_URL\"]",
                "apiKey": "=$property[\"OPENAI_API_KEY\"]"
              },
              "input": {
                "vectorStoreId": "=$activity[CreateVectorStore].id"
              }
            }
          },
          {
            "id": "Return",
            "name": "Return",
            "description": "Simple Return Activity",
            "activity": {
              "ref": "#actreturn"
            }
          }
        ],
        "fe_metadata": "",
        "metadata": {
          "input": [],
          "output": [],
          "fe_metadata": {}
        }
      }
    }
  ],
  "properties": [
    {
      "name": "OPENAI_API_KEY",
      "type": "string",
      "value": "REPLACE_ME"
    },
    {
      "name": "OPENAI_API_ENDPOINT_URL",
      "type": "string",
      "value": "https://api.openai.com/v1"
    }
  ],
  "connections": {},
  "contrib": "",
  "metadata": {
    "endpoints": [],
    "flogoVersion": "2.26.0"
  }
}